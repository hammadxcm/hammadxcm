{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "paths": {
      "@config/*": ["src/config/*"],
      "@components/*": ["src/components/*"],
      "@react/*": ["src/components/react/*"],
      "@scripts/*": ["src/scripts/*"],
      "@i18n/*": ["src/i18n/*"],
      "@utils/*": ["src/utils/*"]
    }
  }
}
