---
import { LOCALES, DEFAULT_LOCALE } from '@i18n/types';
import type { Locale } from '@i18n/types';
import { config } from '@config/index';
import { getTranslations, getDirection, localePath } from '@i18n/index';
import Layout from '../../../layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import SectionHeader from '@components/SectionHeader.astro';
import Contribution3DGraph from '@components/Contribution3DGraph.astro';
import Footer from '@components/Footer.astro';

export function getStaticPaths() {
  return LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: Locale };
const translations = await getTranslations(locale);
const dir = getDirection(locale);
const homeUrl = localePath('', locale);
const pageTitle = `3D Contribution Graph | ${config.site.name}`;

const variants = [
  { key: 'profile-green-animate', label: 'Green (animated)' },
  { key: 'profile-green', label: 'Green' },
  { key: 'profile-night-view', label: 'Night view' },
  { key: 'profile-night-green', label: 'Night green' },
  { key: 'profile-night-rainbow', label: 'Night rainbow' },
  { key: 'profile-season-animate', label: 'Season (animated)' },
  { key: 'profile-season', label: 'Season' },
  { key: 'profile-south-season-animate', label: 'South season (animated)' },
  { key: 'profile-south-season', label: 'South season' },
  { key: 'profile-gitblock', label: 'Gitblock' },
];
---

<Layout
  title={pageTitle}
  description="3D contribution graph showcasing daily commit activity, regenerated every morning."
  locale={locale}
  dir={dir}
  translations={translations}
>
  <Nav translations={translations} locale={locale} baseUrl={homeUrl} />

  <main class="listing-page" data-listing-section="3d-contrib">
    <a href={homeUrl} class="listing-back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      {translations.listing.backToHome}
    </a>

    <SectionHeader
      label="// 3D contributions"
      title="3D Contribution Graph"
      transitionId="section-3d-contrib"
    />

    <p class="contrib-3d-intro">
      <a href="https://github.com/yoshi389111/github-profile-3d-contrib" target="_blank" rel="noreferrer noopener">
        yoshi389111/github-profile-3d-contrib
      </a>
    </p>

    <div class="contrib-3d-gallery">
      {variants.map((v, idx) => (
        <Contribution3DGraph variant={v.key} caption={v.label} eager={idx === 0} />
      ))}
    </div>
  </main>

  <Footer translations={translations} />
</Layout>

<style lang="scss">
  @use '../../../styles/mixins' as *;

  .contrib-3d-intro {
    max-width: 720px;
    margin: 0 auto var(--space-xl);
    text-align: center;
    color: var(--text-dim);
    line-height: 1.6;

    a {
      color: var(--accent);
      text-decoration: none;

      &:hover,
      &:focus-visible {
        text-decoration: underline;
      }
    }
  }

  .contrib-3d-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    max-width: 1100px;
    margin: 0 auto;
  }
</style>
