---
/**
 * Shared Listing Page Template
 * Renders a full page for a single section (testimonials, projects, contributions, certifications).
 * Used by all listing route files.
 */
import { config } from '@config/index';
import { getTranslations, getDirection, localePath } from '@i18n/index';
import type { Locale } from '@i18n/types';
import Layout from '../layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import SectionHeader from '@components/SectionHeader.astro';
import Footer from '@components/Footer.astro';
import TestimonialsListing from '@components/listings/TestimonialsListing.astro';
import ProjectsListing from '@components/listings/ProjectsListing.astro';
import ContributionsListing from '@components/listings/ContributionsListing.astro';
import CertificationsListing from '@components/listings/CertificationsListing.astro';
import AnalyticsListing from '@components/listings/AnalyticsListing.astro';

interface Props {
  locale: Locale;
  section: 'testimonials' | 'projects' | 'contributions' | 'certifications' | 'analytics';
}

const { locale, section } = Astro.props;
const translations = await getTranslations(locale);
const dir = getDirection(locale);
const homeUrl = localePath('', locale);

const sectionConfig = {
  testimonials: { label: translations.testimonials.label, title: translations.testimonials.title },
  projects: { label: translations.projects.label, title: translations.projects.title },
  contributions: { label: translations.contributions.label, title: translations.contributions.title },
  certifications: { label: translations.certs.label, title: translations.certs.title },
  analytics: { label: translations.analytics.label, title: translations.analytics.title },
};

const { label, title: sectionTitle } = sectionConfig[section];
const pageTitle = `${sectionTitle} | ${config.site.name}`;
---

<Layout
  title={pageTitle}
  description={translations.meta.description}
  locale={locale}
  dir={dir}
  translations={translations}
>
  <Nav translations={translations} locale={locale} baseUrl={homeUrl} />

  <main class="listing-page" data-listing-section={section}>
    <a href={homeUrl} class="listing-back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      {translations.listing.backToHome}
    </a>

    <SectionHeader label={label} title={sectionTitle} transitionId={`section-${section}`} />

    {section === 'testimonials' && <TestimonialsListing />}
    {section === 'projects' && <ProjectsListing translations={translations} />}
    {section === 'contributions' && <ContributionsListing translations={translations} />}
    {section === 'certifications' && <CertificationsListing translations={translations} />}
    {section === 'analytics' && <AnalyticsListing translations={translations} />}
  </main>

  <div class="hacker-toast-container" id="hackerToastContainer" aria-live="polite" aria-atomic="false"></div>
  <div class="levelup-overlay" id="levelUpOverlay" aria-hidden="true">
    <div class="levelup-content">
      <div class="levelup-icon">&#x2B06;</div>
      <div class="levelup-num" id="levelUpNum">LEVEL 2</div>
      <div class="levelup-name" id="levelUpName">Packet Sniffer</div>
    </div>
  </div>

  <Footer translations={translations} />
</Layout>
