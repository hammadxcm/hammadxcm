---
/**
 * Full Projects Listing — all projects (featured + dynamic) in a grid.
 * No hidden items, no view-more logic.
 */
import FeaturedProjectCard from '../cards/FeaturedProjectCard.astro';
import DynamicRepoCard from '../cards/DynamicRepoCard.astro';
import type { TranslationMap } from '@i18n/types';
import { getProjectData } from '../../utils/project-data';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const { featured, dynamicRepos, downloadCounts } = getProjectData();
---

<div class="projects-listing-grid">
  {featured.map((project) => {
    const pkgKey = project.npmPackage || project.gemName || '';
    const dlCount = pkgKey ? (downloadCounts[pkgKey] || 0) : 0;
    return (
      <FeaturedProjectCard project={project} dlCount={dlCount} base={base} />
    );
  })}

  {dynamicRepos.map((repo) => (
    <DynamicRepoCard
      repo={repo}
      base={base}
      viewRepoLabel={translations.projects.viewRepo}
    />
  ))}
</div>

<style lang="scss" is:global>
  @use '../../styles/mixins' as *;
  @use '../../styles/utilities/project-card' as *;

  .projects-listing-grid {
    @include project-card-base;
    @include responsive-grid;
  }
</style>
