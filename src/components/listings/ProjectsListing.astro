---
/**
 * Full Projects Listing — top 25 projects sorted by downloads, with pagination.
 * Pagination is handled by the shared pagination module (src/scripts/interactions/pagination.ts).
 */
import FeaturedProjectCard from '../cards/FeaturedProjectCard.astro';
import DynamicRepoCard from '../cards/DynamicRepoCard.astro';
import type { TranslationMap } from '@i18n/types';
import { getProjectData } from '../../utils/project-data';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const { projects } = getProjectData();

const MAX_PROJECTS = 25;
const PAGE_SIZE = 9;
const allProjects = projects.slice(0, MAX_PROJECTS);
---

<div class="projects-listing-grid" id="projects-listing-grid" data-page-size={PAGE_SIZE}>
  {allProjects.map((item, idx) => {
    const hidden = idx >= PAGE_SIZE;
    return item.kind === 'featured' ? (
      <FeaturedProjectCard
        project={item.project}
        dlCount={item.downloads}
        base={base}
        hidden={hidden}
      />
    ) : (
      <DynamicRepoCard
        repo={item.repo}
        base={base}
        viewRepoLabel={translations.projects.viewRepo}
        hidden={hidden}
      />
    );
  })}
</div>

{allProjects.length > PAGE_SIZE && (
  <nav
    class="pagination-controls"
    id="projects-pagination"
    aria-label="Projects pagination"
    data-total={allProjects.length}
    data-page-size={PAGE_SIZE}
    data-label-prev={translations.listing.previous}
    data-label-next={translations.listing.next}
    data-label-page={translations.listing.page}
    data-label-of={translations.listing.of}
    data-label-showing={translations.listing.showing}
  >
  </nav>
)}

<style lang="scss" is:global>
  @use '../../styles/mixins' as *;
  @use '../../styles/utilities/project-card' as *;

  .projects-listing-grid {
    @include project-card-base;
    @include responsive-grid;
  }

  .project-hidden {
    display: none !important;
  }
</style>
