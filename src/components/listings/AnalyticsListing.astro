---
/**
 * Full Analytics Listing — dashboard with hero stats, heatmap, language ring,
 * quick insights, and platform panels.
 */
import GitHubPanel from '../analytics/GitHubPanel.astro';
import LeetCodePanel from '../analytics/LeetCodePanel.astro';
import StackOverflowPanel from '../analytics/StackOverflowPanel.astro';
import ProfileViews from '../analytics/ProfileViews.astro';
import AnalyticsCtaRow from '../analytics/AnalyticsCtaRow.astro';
import Contribution3DGraph from '../Contribution3DGraph.astro';
import { config } from '@config/index';
import { langColors } from '@config/lang-colors';
import type { ContributionsData, ProjectsData, ContributionGraphData } from '@config/types';
import type { TranslationMap } from '@i18n/types';
import contributionsRaw from '../../data/contributions.json';
import projectsRaw from '../../data/projects.json';
import graphRaw from '../../data/contribution-graph.json';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const { username, utcOffset } = config.github;
const leetcode = config.leetcode;
const stackoverflow = config.stackoverflow;

const contributions = contributionsRaw as ContributionsData;
const projects = projectsRaw as ProjectsData;
const graphData = graphRaw as ContributionGraphData;
const hasGraphData = graphData?.weeks?.length > 0;
const hasMultiYear = graphData?.years?.length > 1;

// ── Hero Stats ──
const totalRepos = projects.repos.length;
const uniqueStars = new Map<string, number>();
for (const pr of contributions.contributions) {
  uniqueStars.set(pr.repo.fullName, pr.repo.stars);
}
const dedupedStars = [...uniqueStars.values()].reduce((a, b) => a + b, 0);
const prsMerged = contributions.contributions.filter((pr) => pr.state === 'merged').length;
const langSet = new Set<string>();
for (const pr of contributions.contributions) {
  if (pr.repo.language) langSet.add(pr.repo.language);
}
for (const repo of projects.repos) {
  if (repo.language) langSet.add(repo.language);
}
const languagesUsed = langSet.size;

const stats = [
  { label: translations.contributions.repos, value: totalRepos },
  { label: translations.contributions.combinedStars, value: dedupedStars },
  { label: translations.contributions.prsMerged, value: prsMerged },
  { label: translations.contributions.languages, value: languagesUsed },
];

// ── Heatmap: contribution grid ──
type HeatmapWeek = { weekStart: string; days: { date: string; count: number; level: number }[] };
let heatmapWeeksData: HeatmapWeek[] = [];
let heatmapTotal = 0;

if (hasGraphData) {
  // Use real GitHub contribution graph data
  heatmapTotal = graphData.totalContributions;
  heatmapWeeksData = graphData.weeks.map((week) => ({
    weekStart: week.contributionDays[0]?.date || '',
    days: week.contributionDays.map((day) => ({
      date: day.date,
      count: day.count,
      level: day.level,
    })),
  }));
} else {
  // Fallback: PR-based heatmap
  const heatmapWeekCount = 52;
  const today = new Date();
  const dayOfWeek = today.getDay();
  const totalCells = heatmapWeekCount * 7 + dayOfWeek + 1;
  const startDate = new Date(today);
  startDate.setDate(startDate.getDate() - totalCells + 1);

  const prDateCounts = new Map<string, number>();
  for (const pr of contributions.contributions) {
    const d = pr.mergedAt.slice(0, 10);
    prDateCounts.set(d, (prDateCounts.get(d) || 0) + 1);
  }

  let currentWeek: HeatmapWeek = { weekStart: '', days: [] };
  for (let i = 0; i < totalCells; i++) {
    const d = new Date(startDate);
    d.setDate(d.getDate() + i);
    const dateStr = d.toISOString().slice(0, 10);
    const count = prDateCounts.get(dateStr) || 0;
    const level = count === 0 ? 0 : count === 1 ? 1 : count === 2 ? 2 : count <= 4 ? 3 : 4;
    heatmapTotal += count;

    if (d.getDay() === 0 || i === 0) {
      currentWeek = { weekStart: dateStr, days: [] };
      heatmapWeeksData.push(currentWeek);
    }
    currentWeek.days.push({ date: dateStr, count, level });
  }
}

// Compute month labels from week data
const monthLabels: { label: string; colIndex: number }[] = [];
const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
let lastMonth = -1;
for (let i = 0; i < heatmapWeeksData.length; i++) {
  const firstDay = heatmapWeeksData[i].days[0];
  if (firstDay) {
    const month = new Date(firstDay.date).getMonth();
    if (month !== lastMonth) {
      monthLabels.push({ label: monthNames[month], colIndex: i });
      lastMonth = month;
    }
  }
}

// ── Language Ring ──
const langCounts = new Map<string, number>();
for (const pr of contributions.contributions) {
  const lang = pr.repo.language || 'Other';
  langCounts.set(lang, (langCounts.get(lang) || 0) + 1);
}
const langEntries = [...langCounts.entries()].sort((a, b) => b[1] - a[1]);
const totalPRs = contributions.contributions.length;

const langLegend: { name: string; color: string; count: number; pct: number }[] = [];
for (const [lang, count] of langEntries) {
  const pct = (count / totalPRs) * 100;
  const color = langColors[lang] || '#8b949e';
  langLegend.push({ name: lang, color, count, pct: Math.round(pct) });
}

// ── Quick Insights ──
const monthCounts = new Map<string, number>();
for (const pr of contributions.contributions) {
  const m = pr.mergedAt.slice(0, 7);
  monthCounts.set(m, (monthCounts.get(m) || 0) + 1);
}
const sortedMonths = [...monthCounts.entries()].sort((a, b) => b[1] - a[1]);
const mostActiveMonth = sortedMonths[0]?.[0] || '-';
const topLanguage = langEntries[0]?.[0] || '-';
const activeMonths = monthCounts.size || 1;
const avgPRsPerMonth = Math.round(totalPRs / activeMonths);

---

<div class="dashboard-ambient">
  <!-- Hero Stats -->
  <div class="dash-hero-stats">
    {stats.map((stat) => (
      <div class="dash-hero-stat glass">
        <span class="dash-hero-value">{stat.value.toLocaleString()}</span>
        <span class="dash-hero-label">{stat.label}</span>
      </div>
    ))}
  </div>

  <!-- Contribution Heatmap -->
  <div class="analytics-heatmap-panel glass" id="contributionGraph">
    <div class="heatmap-header">
      <h3 class="dash-panel-title">{translations.contributionAnalytics?.contributionGraph || 'Contribution Graph'}</h3>
      <div class="heatmap-controls">
        {hasMultiYear && (
          <div class="heatmap-year-tabs">
            {graphData.years.map((y, i) => (
              <button
                class={`heatmap-year-btn ${i === 0 ? 'active' : ''}`}
                data-year-index={i}
              >{y.year}</button>
            ))}
          </div>
        )}
        <div class="heatmap-filters">
          <button class="heatmap-filter-btn active" data-range="1Y">1Y</button>
          <button class="heatmap-filter-btn" data-range="6M">6M</button>
          <button class="heatmap-filter-btn" data-range="3M">3M</button>
          <button class="heatmap-filter-btn" data-range="1M">1M</button>
        </div>
      </div>
    </div>
    <div class="heatmap-total" data-total={heatmapTotal}>
      {(translations.contributionAnalytics?.totalContributions || '{count} contributions in the last year').replace('{count}', heatmapTotal.toLocaleString())}
    </div>
    <div class="heatmap-months" id="heatmapMonths">
      {monthLabels.map((m) => (
        <span class="heatmap-month-label" style={`--col: ${m.colIndex}`}>{m.label}</span>
      ))}
    </div>
    <div class="heatmap-graph-wrapper">
      <div class="heatmap-days">
        <span></span>
        <span>Mon</span>
        <span></span>
        <span>Wed</span>
        <span></span>
        <span>Fri</span>
        <span></span>
      </div>
      <div class="dash-heatmap" id="heatmapGrid">
        {heatmapWeeksData.map((week) => (
          <div class="heatmap-week" data-week-start={week.weekStart}>
            {week.days.map((day) => (
              <div
                class="dash-heatmap-cell"
                data-level={day.level}
                data-count={day.count}
                data-date={day.date}
                title={`${day.date}: ${day.count} contribution${day.count !== 1 ? 's' : ''}`}
              />
            ))}
          </div>
        ))}
      </div>
    </div>
    <div class="heatmap-legend">
      <span class="heatmap-legend-label">{translations.contributions?.less || 'Less'}</span>
      <div class="dash-heatmap-cell" data-level="0" />
      <div class="dash-heatmap-cell" data-level="1" />
      <div class="dash-heatmap-cell" data-level="2" />
      <div class="dash-heatmap-cell" data-level="3" />
      <div class="dash-heatmap-cell" data-level="4" />
      <span class="heatmap-legend-label">{translations.contributions?.more || 'More'}</span>
    </div>
  </div>
  {hasMultiYear && (
    <script is:inline define:vars={{ yearsData: graphData.years }}>
      window.__contributionYears = yearsData;
    </script>
  )}

  <!-- Language Ring + Quick Insights -->
  <div class="analytics-ring-insights">
    <div class="analytics-ring-panel glass">
      <h3 class="dash-panel-title">{translations.contributionAnalytics?.languageBreakdown || 'Languages'}</h3>
      <div class="ring-layout">
        <div
          class="dash-chart-container dash-chart-container--ring"
          data-chart-langs={JSON.stringify(langLegend)}
          role="img"
          aria-label={`Language distribution: ${langLegend.map((l) => `${l.name} ${l.pct}%`).join(', ')}`}
        ></div>
        <div class="lang-legend">
          {langLegend.map((item) => (
            <div class="lang-legend-row">
              <span class="lang-dot" style={`--dot-color: ${item.color}`} />
              <span class="lang-name">{item.name}</span>
              <span class="lang-count">{item.count} ({item.pct}%)</span>
              <div class="dash-pct-bar">
                <div class="dash-pct-fill" style={`width:${item.pct}%; --bar-color:${item.color}`} />
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="analytics-insights-panel glass">
      <h3 class="dash-panel-title">{translations.contributionAnalytics?.impactMetrics || 'Quick Insights'}</h3>
      <div class="dash-insights">
        <div class="dash-insight">
          <div class="dash-insight-label">{translations.contributionAnalytics?.mostActiveMonth || 'Most Active Month'}</div>
          <div class="dash-insight-value">{mostActiveMonth}</div>
        </div>
        <div class="dash-insight">
          <div class="dash-insight-label">{translations.contributionAnalytics?.topLanguage || 'Top Language'}</div>
          <div class="dash-insight-value">{topLanguage}</div>
        </div>
        <div class="dash-insight">
          <div class="dash-insight-label">{translations.contributionAnalytics?.avgPRsPerMonth || 'Avg PRs/Month'}</div>
          <div class="dash-insight-value">{avgPRsPerMonth}</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Platform Panels -->
  <div class="analytics-platforms">
    <GitHubPanel username={username} utcOffset={utcOffset} translations={translations} />

    {leetcode && (
      <LeetCodePanel username={leetcode.username} translations={translations} />
    )}

    {stackoverflow && (
      <StackOverflowPanel userId={stackoverflow.userId} translations={translations} />
    )}
  </div>

  <!-- 3D Contribution Graph -->
  <Contribution3DGraph
    id="contrib-3d"
    themeAware
    caption="3D contribution graph — regenerated daily"
  />

  <ProfileViews username={username} translations={translations} previousCount={4999} />

  <AnalyticsCtaRow username={username} translations={translations} />

  <div class="dev-quote reveal">
    <img data-stat="quote" src="https://quotes-github-readme.vercel.app/api?type=horizontal&theme=tokyonight" alt={translations.analytics.alt.devQuote} loading="lazy" decoding="async" width="600" height="150">
  </div>
</div>

<style lang="scss">
  @use '../../styles/mixins' as *;

  .analytics-heatmap-panel {
    padding: 1.5rem;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;

    @include respond-to(mobile) {
      padding: 1rem;
    }
  }

  .heatmap-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
    gap: 0.5rem;

    .dash-panel-title {
      margin-bottom: 0;
    }
  }

  .heatmap-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .heatmap-year-tabs {
    display: flex;
    gap: 0.25rem;
  }

  .heatmap-year-btn {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    border: 1px solid rgba(var(--accent-glow), 0.12);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s ease;

    &:hover {
      border-color: rgba(var(--accent-glow), 0.3);
      color: var(--text);
    }

    &.active {
      background: rgba(var(--accent-glow), 0.1);
      border-color: rgba(var(--accent-glow), 0.3);
      color: var(--accent);
    }
  }

  .heatmap-filters {
    display: flex;
    gap: 0.35rem;
  }

  .heatmap-filter-btn {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.25rem 0.6rem;
    border-radius: 12px;
    border: 1px solid rgba(var(--accent-glow), 0.2);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all 0.2s ease;

    &:hover {
      border-color: rgba(var(--accent-glow), 0.4);
      color: var(--text);
    }

    &.active {
      background: rgba(var(--accent-glow), 0.15);
      border-color: var(--accent);
      color: var(--accent);
    }
  }

  .heatmap-total {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }

  .heatmap-graph-wrapper {
    display: flex;
    overflow-x: auto;
    direction: ltr;

    @include hide-scrollbar;
  }

  .heatmap-days {
    display: grid;
    grid-template-rows: repeat(7, 14px);
    gap: 3px;
    flex-shrink: 0;
    margin-inline-end: 4px;

    span {
      font-family: var(--font-mono);
      font-size: 0.55rem;
      color: var(--text-dim);
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-inline-end: 2px;
      line-height: 1;
    }

    @include respond-to(mobile) {
      grid-template-rows: repeat(7, 12px);
      gap: 2px;
    }
  }

  .heatmap-legend {
    display: flex;
    align-items: center;
    gap: 4px;
    justify-content: flex-end;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);

    .dash-heatmap-cell {
      width: 14px;
      height: 14px;
    }
  }

  .heatmap-legend-label {
    margin-inline: 0.25rem;
  }

  .analytics-ring-insights {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;

    @include respond-to(tablet) {
      grid-template-columns: 1fr;
    }
  }

  .analytics-ring-panel,
  .analytics-insights-panel {
    padding: 1.5rem;
    border-radius: var(--radius-md);

    @include respond-to(mobile) {
      padding: 1rem;
    }
  }

  .ring-layout {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;

    @include respond-to(mobile) {
      flex-direction: column;
      align-items: center;
    }
  }

  .lang-legend {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .lang-legend-row {
    display: grid;
    grid-template-columns: 10px 1fr auto;
    grid-template-rows: auto auto;
    gap: 0 0.5rem;
    align-items: center;
    font-size: 0.78rem;
    font-family: var(--font-mono);
  }

  .lang-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--dot-color);
    grid-row: 1;
  }

  .lang-name {
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    grid-row: 1;
  }

  .lang-count {
    color: var(--text-dim);
    flex-shrink: 0;
    grid-row: 1;
  }

  .lang-legend-row .dash-pct-bar {
    grid-column: 2 / -1;
    grid-row: 2;
  }

  .analytics-platforms {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .dash-chart-container--ring {
    max-width: 180px;
    flex-shrink: 0;

    @include respond-to(mobile) {
      max-width: 140px;
    }
  }

  .dev-quote {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: 2rem;

    img {
      max-width: 600px;
      width: 100%;
      height: auto;
      border-radius: var(--radius-md);
      background: var(--bg-card);
      border: 1px solid var(--glass-border);
    }

    @include respond-to(mobile) {
      img { max-width: 100%; }
    }
  }
</style>

<script>
  import { initDashboardCharts } from '../../scripts/dashboard-charts';
  document.addEventListener('astro:page-load', initDashboardCharts);

  interface YearData {
    year: string;
    totalContributions: number;
    weeks: { contributionDays: { date: string; count: number; level: number }[] }[];
  }

  document.addEventListener('astro:page-load', () => {
    const grid = document.getElementById('heatmapGrid');
    const monthsEl = document.getElementById('heatmapMonths');
    const totalEl = document.querySelector<HTMLElement>('.heatmap-total');
    const filtersEl = document.querySelector<HTMLElement>('.heatmap-filters');
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.heatmap-filter-btn');
    const yearBtns = document.querySelectorAll<HTMLButtonElement>('.heatmap-year-btn');
    if (!grid) return;

    const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    const yearsData: YearData[] = (window as any).__contributionYears || [];

    /** Render week columns into the heatmap grid */
    function renderWeeks(weeks: YearData['weeks']) {
      grid!.innerHTML = '';
      for (const week of weeks) {
        const weekEl = document.createElement('div');
        weekEl.className = 'heatmap-week';
        weekEl.dataset.weekStart = week.contributionDays[0]?.date || '';
        for (const day of week.contributionDays) {
          const cell = document.createElement('div');
          cell.className = 'dash-heatmap-cell';
          cell.dataset.level = String(day.level);
          cell.dataset.count = String(day.count);
          cell.dataset.date = day.date;
          cell.title = `${day.date}: ${day.count} contribution${day.count !== 1 ? 's' : ''}`;
          weekEl.appendChild(cell);
        }
        grid!.appendChild(weekEl);
      }
    }

    /** Render month labels from visible weeks */
    function renderMonths() {
      if (!monthsEl) return;
      monthsEl.innerHTML = '';
      const weekEls = grid!.querySelectorAll<HTMLElement>('.heatmap-week:not(.heatmap-hidden)');
      let lastMonth = -1;
      let colIndex = 0;
      weekEls.forEach((weekEl) => {
        const firstDate = weekEl.dataset.weekStart || '';
        if (firstDate) {
          const month = new Date(firstDate).getMonth();
          if (month !== lastMonth) {
            const span = document.createElement('span');
            span.className = 'heatmap-month-label';
            span.style.setProperty('--col', String(colIndex));
            span.textContent = monthNames[month];
            monthsEl!.appendChild(span);
            lastMonth = month;
          }
        }
        colIndex++;
      });
    }

    /** Apply range filter to currently rendered weeks */
    function applyRangeFilter(range: string) {
      const weeks = grid!.querySelectorAll<HTMLElement>('.heatmap-week');
      if (range === '1Y') {
        weeks.forEach((w) => w.classList.remove('heatmap-hidden'));
      } else {
        const months = range === '6M' ? 6 : range === '3M' ? 3 : 1;
        const now = new Date();
        const cutoff = new Date(now.getFullYear(), now.getMonth() - months, now.getDate());
        const cutoffStr = cutoff.toISOString().slice(0, 10);
        weeks.forEach((w) => {
          w.classList.toggle('heatmap-hidden', (w.dataset.weekStart || '') < cutoffStr);
        });
      }
      updateCount();
      renderMonths();
    }

    /** Update the total contributions counter */
    function updateCount() {
      if (!totalEl) return;
      let count = 0;
      grid!.querySelectorAll<HTMLElement>('.heatmap-week:not(.heatmap-hidden) .dash-heatmap-cell').forEach((cell) => {
        count += parseInt(cell.dataset.count || '0', 10);
      });
      totalEl.textContent = (totalEl.textContent || '').replace(/[\d,]+/, count.toLocaleString());
    }

    /** Switch to a specific year's data */
    function switchYear(index: number) {
      const year = yearsData[index];
      if (!year) return;
      const isCurrentYear = index === 0;

      renderWeeks(year.weeks);

      // Show range filters only for "Last year" (current), hide for historical
      if (filtersEl) {
        filtersEl.style.display = isCurrentYear ? '' : 'none';
      }

      // Reset range filter
      filterBtns.forEach((b) => b.classList.toggle('active', b.dataset.range === '1Y'));

      // Update total text
      if (totalEl) {
        totalEl.textContent = (totalEl.textContent || '').replace(/[\d,]+/, year.totalContributions.toLocaleString());
      }
      renderMonths();
    }

    // Year tab click handlers
    yearBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        yearBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        switchYear(parseInt(btn.dataset.yearIndex || '0', 10));
      });
    });

    // Range filter click handlers (only apply for current year)
    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        applyRangeFilter(btn.dataset.range || '1Y');
      });
    });
  });
</script>
