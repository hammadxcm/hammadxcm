---
/**
 * Full Contributions Listing — all PRs with summary stats + client-side pagination.
 * Wrapped in dashboard-ambient for ambient orb effects.
 */
import ContributionCard from '../ContributionCard.astro';
import ContributionsSummary from '../ContributionsSummary.astro';
import ContributionsAnalytics from './ContributionsAnalytics.astro';
import type { ContributionsData } from '@config/types';
import type { TranslationMap } from '@i18n/types';
import { sortContributions } from '../../utils/contribution-sort';
import contributionsRaw from '../../data/contributions.json';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const contributions = contributionsRaw as ContributionsData;
const prs = sortContributions(contributions.contributions);
const PAGE_SIZE = 12;
---

<div class="dashboard-ambient">
  <ContributionsSummary prs={prs} translations={translations} />

  <ContributionsAnalytics prs={prs} translations={translations} />

  <div
    class="contributions-listing-grid"
    id="contributions-paginated-grid"
    data-page-size={PAGE_SIZE}
  >
    {prs.map((pr, idx) => (
      <ContributionCard pr={pr} hidden={idx >= PAGE_SIZE} translations={translations} />
    ))}
  </div>

  {prs.length > PAGE_SIZE && (
    <nav
      class="pagination-controls"
      id="contributions-pagination"
      aria-label="Pagination"
      data-total={prs.length}
      data-page-size={PAGE_SIZE}
      data-label-prev={translations.listing.previous}
      data-label-next={translations.listing.next}
      data-label-page={translations.listing.page}
      data-label-of={translations.listing.of}
      data-label-showing={translations.listing.showing}
    >
    </nav>
  )}
</div>

<style lang="scss" is:global>
  @use '../../styles/mixins' as *;

  .contributions-listing-grid {
    @include responsive-grid;
  }

  .pagination-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
    padding: 1rem 0;
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    background: var(--glass-bg);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out-expo);

    &:hover:not(:disabled) {
      border-color: var(--accent);
      box-shadow: 0 0 20px rgba(var(--accent-rgb), 0.15);
      transform: translateY(-2px);
    }

    &:disabled {
      opacity: 0.35;
      cursor: not-allowed;
      pointer-events: none;
    }

    svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
    }
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .pagination-page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    background: var(--glass-bg);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out-expo);

    &:hover:not(.active) {
      border-color: var(--accent);
      color: var(--accent);
      transform: translateY(-2px);
    }

    &.active {
      background: rgba(var(--accent-rgb), 0.15);
      border-color: var(--accent);
      color: var(--accent);
      box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.2);
      pointer-events: none;
    }
  }

  .pagination-ellipsis {
    font-family: var(--font-mono);
    color: var(--text-dim);
    padding: 0 0.25rem;
    font-size: 0.85rem;
    user-select: none;
  }

  .pagination-info {
    width: 100%;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
    letter-spacing: 0.03em;
  }

  @include respond-to(mobile) {
    .pagination-controls { gap: 0.5rem; }
    .pagination-btn { padding: 0.5rem 0.9rem; font-size: 0.72rem; }
    .pagination-page { width: 2rem; height: 2rem; font-size: 0.72rem; }
  }
</style>
