---
/**
 * Full Contributions Listing — summary stats + analytics + an interactive browser
 * (search / filter / sort, Cards or Table view, pagination + Show all, detail modal).
 * Wrapped in dashboard-ambient for ambient orb effects.
 */
import ContributionCard from '../ContributionCard.astro';
import ContributionRow from '../ContributionRow.astro';
import ContributionsSummary from '../ContributionsSummary.astro';
import ContributionsAnalytics from './ContributionsAnalytics.astro';
import ContributionsToolbar from './ContributionsToolbar.astro';
import ContributionDetailModal from '../ContributionDetailModal.astro';
import type { ContributionsData } from '@config/types';
import type { TranslationMap } from '@i18n/types';
import { sortContributions } from '../../utils/contribution-sort';
import { DEFAULT_STATES, distinctLanguages, distinctOrgs } from '../../utils/contribution-filter';
import { safeJsonForScript } from '../../utils/json-island';
import contributionsRaw from '../../data/contributions.json';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const contributions = contributionsRaw as ContributionsData;
const prs = sortContributions(contributions.contributions);
const languages = distinctLanguages(prs);
const orgs = distinctOrgs(prs);
const PAGE_SIZE = 24;

// SSR initial visibility must match the controller's first render: default state
// filter (Merged + Open) + the first page. Closed PRs start hidden — no flash.
const defaultStateSet = new Set(DEFAULT_STATES);
const initiallyVisible = new Set<number>();
let shownCount = 0;
prs.forEach((pr, idx) => {
  if (defaultStateSet.has(pr.state) && shownCount < PAGE_SIZE) {
    initiallyVisible.add(idx);
    shownCount++;
  }
});

// Data island for the client controller (modal + filter/sort).
const dataJson = safeJsonForScript(prs);

const cb = translations.contributionsBrowser;
const l = translations.listing;
---

<div class="dashboard-ambient">
  <ContributionsSummary prs={prs} translations={translations} />

  <ContributionsAnalytics prs={prs} translations={translations} />

  <section
    class="contributions-browser"
    id="contributions-browser"
    data-page-size={PAGE_SIZE}
    data-total={prs.length}
    data-label-prev={l.previous}
    data-label-next={l.next}
    data-label-page={l.page}
    data-label-of={l.of}
    data-label-showing={l.showing}
    data-label-show-all={cb.showAll}
    data-label-show-less={cb.showLess}
    data-label-result-count={cb.resultCount}
    data-label-no-results={cb.noResults}
  >
    <ContributionsToolbar translations={translations} languages={languages} orgs={orgs} />

    <div class="contrib-result-count" id="contrib-result-count" aria-live="polite"></div>

    {/* Cards view */}
    <div class="contributions-cards-view" id="contributions-cards-view">
      <div class="contributions-listing-grid" id="contributions-cards-grid">
        {prs.map((pr, idx) => (
          <ContributionCard
            pr={pr}
            id={idx}
            interactive="modal"
            hidden={!initiallyVisible.has(idx)}
            translations={translations}
          />
        ))}
      </div>
    </div>

    {/* Table view */}
    <div class="contributions-table-view contrib-hidden" id="contributions-table-view">
      <div class="contrib-table-scroll">
        <table class="contrib-table">
          <thead>
            <tr>
              <th scope="col">{cb.colState}</th>
              <th scope="col">{cb.colRepo}</th>
              <th scope="col">{cb.colPr}</th>
              <th scope="col">{cb.colLang}</th>
              <th scope="col" class="contrib-th-sort" data-sort-key="stars">
                <button type="button" class="contrib-th-btn">{cb.colStars}</button>
              </th>
              <th scope="col" class="contrib-th-sort" data-sort-key="impact">
                <button type="button" class="contrib-th-btn">{cb.colImpact}</button>
              </th>
              <th scope="col" class="contrib-th-sort" data-sort-key="recent">
                <button type="button" class="contrib-th-btn">{cb.colWhen}</button>
              </th>
            </tr>
          </thead>
          <tbody id="contributions-table-body">
            {prs.map((pr, idx) => (
              <ContributionRow pr={pr} id={idx} hidden={!initiallyVisible.has(idx)} translations={translations} />
            ))}
          </tbody>
        </table>
      </div>
    </div>

    {/* Empty state */}
    <div class="contrib-empty contrib-hidden" id="contrib-empty">{cb.noResults}</div>

    {/* Pagination (controller-rendered) + Show all */}
    <nav class="pagination-controls" id="contributions-pagination" aria-label="Pagination"></nav>
    <div class="contrib-showall-wrap">
      <button type="button" class="contrib-show-all" id="contrib-show-all" hidden></button>
    </div>

    <script type="application/json" id="contributions-data" set:html={dataJson}></script>
  </section>

  <ContributionDetailModal translations={translations} />
</div>

<style lang="scss" is:global>
  @use '../../styles/mixins' as *;

  .contributions-listing-grid {
    @include responsive-grid;
  }

  .pagination-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
    padding: 1rem 0;

    &:empty {
      display: none;
    }
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.25rem;
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    background: var(--glass-bg);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out-expo);

    &:hover:not(:disabled) {
      border-color: var(--accent);
      box-shadow: 0 0 20px rgba(var(--accent-rgb), 0.15);
      transform: translateY(-2px);
    }

    &:disabled {
      opacity: 0.35;
      cursor: not-allowed;
      pointer-events: none;
    }

    svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
    }
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .pagination-page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    background: var(--glass-bg);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--duration-normal) var(--ease-out-expo);

    &:hover:not(.active) {
      border-color: var(--accent);
      color: var(--accent);
      transform: translateY(-2px);
    }

    &.active {
      background: rgba(var(--accent-rgb), 0.15);
      border-color: var(--accent);
      color: var(--accent);
      box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.2);
      pointer-events: none;
    }
  }

  .pagination-ellipsis {
    font-family: var(--font-mono);
    color: var(--text-dim);
    padding: 0 0.25rem;
    font-size: 0.85rem;
    user-select: none;
  }

  .pagination-info {
    width: 100%;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    margin-top: 0.25rem;
    letter-spacing: 0.03em;
  }

  @include respond-to(mobile) {
    .pagination-controls { gap: 0.5rem; }
    .pagination-btn { padding: 0.5rem 0.9rem; font-size: 0.72rem; }
    .pagination-page { width: 2rem; height: 2rem; font-size: 0.72rem; }
  }
</style>
