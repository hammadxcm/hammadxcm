---
/**
 * LeetCode Analytics Panel
 * Tabbed LeetCode stats card with activity/heatmap/contest views.
 */
import type { TranslationMap } from '@i18n/types';

interface Props {
  username: string;
  translations: TranslationMap;
}

const { username, translations } = Astro.props;
---

<div class="analytics-subsection">
  <h3 class="analytics-subsection-title">{translations.analytics.leetcode}</h3>
  <div class="analytics-grid" data-leetcode-user={username}>
    <div class="analytics-tabs reveal">
      <button class="analytics-tab active" data-ext="activity">{translations.analytics.tabs.activity}</button>
      <button class="analytics-tab" data-ext="heatmap">{translations.analytics.tabs.heatmap}</button>
      <button class="analytics-tab" data-ext="contest">{translations.analytics.tabs.contest}</button>
    </div>
    <div class="analytics-responsive-card analytics-responsive-card--leetcode reveal">
      <img data-stat="leetcode-card" data-current-ext="activity"
        src={`https://leetcard.jacoblin.cool/${username}?theme=dark&font=Source%20Code%20Pro&ext=activity&colors=0D1117,161B22,FFFFFF,8B949E,5BCDEC,58A6FF,3FB950,00BFA5`}
        alt={translations.analytics.alt.leetcodeStats} loading="lazy" width="750" height="380">
    </div>
    <div class="analytics-cta-row reveal">
      <a href={`https://leetcode.com/u/${username}`} target="_blank" rel="noopener noreferrer" class="analytics-cta glass glow-border">
        <div class="analytics-cta__icon">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.483 0a1.374 1.374 0 0 0-.961.438L7.116 6.226l-3.854 4.126a5.266 5.266 0 0 0-1.209 2.104 5.35 5.35 0 0 0-.125.513 5.527 5.527 0 0 0 .062 2.362 5.83 5.83 0 0 0 .349 1.017 5.938 5.938 0 0 0 1.271 1.818l4.277 4.193.039.038c2.248 2.165 5.852 2.133 8.063-.074l2.396-2.392c.54-.54.54-1.414.003-1.955a1.378 1.378 0 0 0-1.951-.003l-2.396 2.392a3.021 3.021 0 0 1-4.205.038l-.02-.019-4.276-4.193c-.652-.64-.972-1.469-.948-2.263a2.68 2.68 0 0 1 .066-.523 2.545 2.545 0 0 1 .619-1.164L9.13 8.114c1.058-1.134 3.204-1.27 4.43-.278l3.501 2.831c.593.48 1.461.387 1.94-.207a1.384 1.384 0 0 0-.207-1.943l-3.5-2.831c-.8-.647-1.766-1.045-2.774-1.202l2.015-2.158A1.384 1.384 0 0 0 13.483 0zm-2.866 12.815a1.38 1.38 0 0 0-1.38 1.382 1.38 1.38 0 0 0 1.38 1.382H20.79a1.38 1.38 0 0 0 1.38-1.382 1.38 1.38 0 0 0-1.38-1.382z"/></svg>
        </div>
        <div class="analytics-cta__body">
          <h3>{translations.analytics.cta.leetcodeProfile}</h3>
          <p>{translations.analytics.cta.leetcodeProfileDesc}</p>
        </div>
        <span class="analytics-cta__arrow">&rarr;</span>
      </a>
    </div>
  </div>
</div>
