---
import ArrowIcon from '../ArrowIcon.astro';
import StarIcon from '../icons/StarIcon.astro';
import ForkIcon from '../icons/ForkIcon.astro';
import DownloadIcon from '../icons/DownloadIcon.astro';
import { getLangColor } from '@config/lang-colors';
import { formatStars, formatDownloads } from '../../utils/format';
import { resolveRepoIcon } from '../../utils/project-icons';

interface Props {
  repo: {
    name: string;
    url: string;
    description?: string | null;
    stars: number;
    forks: number;
    language?: string | null;
    topics: string[];
    downloads?: number;
  };
  base: string;
  viewRepoLabel: string;
  hidden?: boolean;
}

const { repo, base, viewRepoLabel, hidden = false } = Astro.props;
const dotColor = repo.language ? getLangColor(repo.language) : null;
---

<a
  class:list={['project-card', 'project-card--dynamic', 'glass', 'reveal', 'glow-border', { 'project-hidden': hidden }]}
  href={repo.url}
  target="_blank"
  rel="noopener noreferrer"
  data-tilt
>
  <div class="project-icon">
    <img src={resolveRepoIcon(repo, base)} alt={repo.name} width="44" height="44" loading="lazy" decoding="async" />
  </div>
  <div class="project-header-row">
    {repo.language && dotColor && (
      <span class="project-lang">
        <span class="lang-dot" style={`background:${dotColor}`} />
        {repo.language}
      </span>
    )}
    <span class="project-stars">
      <StarIcon />
      {formatStars(repo.stars)}
    </span>
    {repo.forks > 0 && (
      <span class="project-forks">
        <ForkIcon />
        {repo.forks}
      </span>
    )}
    {(repo.downloads ?? 0) > 0 && (
      <span class="project-downloads">
        <DownloadIcon />
        {formatDownloads(repo.downloads!)}
      </span>
    )}
  </div>
  <h3 class="project-name">{repo.name}</h3>
  {repo.description && (
    <p class="project-desc">{repo.description}</p>
  )}
  {repo.topics.length > 0 && (
    <div class="project-tags">
      {repo.topics.slice(0, 5).map((tag) => (
        <span>{tag}</span>
      ))}
    </div>
  )}
  <span class="project-link">
    {viewRepoLabel} <ArrowIcon />
  </span>
</a>
