---
/**
 * Open Source Contributions Section
 * Displays merged PRs as individual cards with rich metadata.
 * Data sourced from src/data/contributions.json (generated by scripts/fetch-contributions.mjs).
 *
 * @depends config.contributions, contributions.json, SectionHeader, ContributionCard, ContributionsSummary
 * @styles Scoped SCSS — grid layout, View More + responsive
 */
import SectionHeader from './SectionHeader.astro';
import ViewAllLink from './ViewAllLink.astro';
import ContributionCard from './ContributionCard.astro';
import ContributionsSummary from './ContributionsSummary.astro';
import NotableSlider from './NotableSlider.astro';
import { config } from '@config/index';
import type { ContributionsData } from '@config/types';
import type { TranslationMap } from '@i18n/types';
import { getLocaleFromUrl, localePath } from '@i18n/index';
import contributionsRaw from '../data/contributions.json';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const contributions = contributionsRaw as ContributionsData;

const enabled = config.contributions?.enabled !== false;
const hasPRs = contributions.contributions.length > 0;
const stateOrder = { merged: 0, open: 1, closed: 2 };
const prs = [...contributions.contributions].sort((a, b) => {
  // Merged first, then Open, then Closed
  const so = (stateOrder[a.state] ?? 9) - (stateOrder[b.state] ?? 9);
  if (so !== 0) return so;
  // Within same state, latest first
  return new Date(b.mergedAt).getTime() - new Date(a.mergedAt).getTime();
});

const INITIAL_SHOW = 6;
const hasMore = prs.length > INITIAL_SHOW;
---

{enabled && hasPRs && (
  <section id="contributions" class="section">
    <SectionHeader label={translations.contributions.label} title={translations.contributions.title} />

    <ContributionsSummary prs={prs} translations={translations} />

    <NotableSlider prs={prs} translations={translations} />

    {/* Per-PR Cards Grid */}
    <div class="contributions-grid stagger" id="contrib-grid">
      {prs.map((pr, idx) => (
        <ContributionCard pr={pr} hidden={hasMore && idx >= INITIAL_SHOW} translations={translations} />
      ))}
    </div>

    {hasMore && (
      <ViewAllLink href={localePath('contributions', locale)} label={translations.listing.viewAll} count={prs.length} />
    )}
  </section>
)}

<style lang="scss">
  @use '../styles/mixins' as *;

  .contributions-grid {
    @include responsive-grid;
  }
</style>
