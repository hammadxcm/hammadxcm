---
/**
 * Global overlay elements: crosshair cursor, cursor trail, scroll progress bar,
 * floating orbs, CRT scan lines, key flash indicator, toast notifications,
 * screen effect overlay, konami overlay, terminal status bar.
 */
import type { TranslationMap } from '@i18n/types';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
---

<!-- Crosshair Cursor (desktop only) -->
<div class="crosshair-cursor" id="crosshairCursor" aria-hidden="true">
  <div class="crosshair-h"></div>
  <div class="crosshair-v"></div>
  <div class="crosshair-dot"></div>
  <div class="crosshair-ring"></div>
</div>

<!-- Cursor Trail Pool -->
<div class="cursor-trail" id="cursorTrail" aria-hidden="true">
  <span></span><span></span><span></span><span></span>
  <span></span><span></span><span></span><span></span>
</div>

<!-- CRT Scan Lines (desktop only) -->
<div class="crt-overlay" id="crtOverlay" aria-hidden="true"></div>

<!-- Key Flash Indicator -->
<div class="key-flash" id="keyFlash" aria-hidden="true"></div>

<!-- Scroll Progress Bar -->
<div class="scroll-progress" id="scrollProgress" role="progressbar" aria-label={translations.a11y.scrollProgress} aria-valuemin="0" aria-valuemax="100"></div>

<!-- Floating Gradient Orbs -->
<div class="orb orb-1" aria-hidden="true"></div>
<div class="orb orb-2" aria-hidden="true"></div>
<div class="orb orb-3" aria-hidden="true"></div>

<!-- Hacker Toast Container -->
<div class="hacker-toast-container" id="hackerToastContainer" aria-live="polite" aria-atomic="false"></div>

<!-- Screen Effect Overlay -->
<div class="screen-effect-overlay" id="screenEffectOverlay" aria-hidden="true">
  <div class="blood-drip"></div>
  <div class="blood-drip"></div>
  <div class="blood-drip"></div>
  <div class="blood-drip"></div>
  <div class="blood-drip"></div>
  <svg class="ice-cracks" viewBox="0 0 1920 1080" preserveAspectRatio="none">
    <path class="crack-line" d="M960,0 L940,120 L970,250 L935,400 L960,540"/>
    <path class="crack-line" d="M960,0 L1000,80 L980,200 L1020,350 L990,480"/>
    <path class="crack-line" d="M960,0 L920,100 L950,220 L910,380 L940,500"/>
  </svg>
  <div class="vhs-tracking"></div>
  <div class="fog-wisp fog-wisp-1"></div>
  <div class="fog-wisp fog-wisp-2"></div>
  <div class="aurora-band"></div>
  <div class="pastel-bloom"></div>
  <div class="shooting-star"></div>
</div>

<!-- Konami Code Overlay -->
<div class="konami-overlay" id="konamiOverlay" aria-hidden="true">
  <div class="konami-text">SYSTEM COMPROMISED</div>
</div>

<!-- CTF Achievement Overlay -->
<div class="ctf-overlay" id="ctfOverlay" aria-hidden="true">
  <div class="ctf-achievement">
    <div class="ctf-icon">&#x1F3C6;</div>
    <div class="ctf-title">ACCESS GRANTED</div>
    <div class="ctf-subtitle">You found all 5 clues and cracked the passphrase.</div>
    <div class="ctf-badge">ELITE HACKER</div>
  </div>
</div>

<!-- Level-Up Overlay -->
<div class="levelup-overlay" id="levelUpOverlay" aria-hidden="true">
  <div class="levelup-content">
    <div class="levelup-icon">&#x2B06;</div>
    <div class="levelup-num" id="levelUpNum">LEVEL 2</div>
    <div class="levelup-name" id="levelUpName">Packet Sniffer</div>
  </div>
</div>

<!-- Terminal Status Bar -->
<!-- CTF Clue 3/5: Third fragment is "SI" -->
<div class="terminal-status-bar" id="terminalStatusBar" aria-hidden="true" data-ctf-clue="3:SI">
  <span class="status-slot" id="statusSlot0"></span>
  <span class="status-sep">|</span>
  <span class="status-slot" id="statusSlot1"></span>
  <span class="status-sep">|</span>
  <span class="status-slot" id="statusSlot2"></span>
  <span class="status-sep">|</span>
  <span class="status-slot" id="statusSlot3"></span>
  <span class="status-sep">|</span>
  <span class="status-slot" id="statusSlot4"></span>
</div>
