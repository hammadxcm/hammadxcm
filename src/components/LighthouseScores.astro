---
/**
 * Lighthouse Performance Scores
 * SVG circular gauges showing Lighthouse CI scores. Data from lighthouse.json.
 *
 * @depends src/data/lighthouse.json (generated by CI)
 * @styles Scoped SCSS — circular gauges + responsive
 */
import lighthouseData from '../data/lighthouse.json';

const { scores } = lighthouseData;
const RADIUS = 22;
const CIRCUMFERENCE = 2 * Math.PI * RADIUS;

const categories = [
  { key: 'performance', label: 'Perf', score: scores.performance },
  { key: 'accessibility', label: 'A11y', score: scores.accessibility },
  { key: 'bestPractices', label: 'BP', score: scores.bestPractices },
  { key: 'seo', label: 'SEO', score: scores.seo },
] as const;

function getColor(score: number): string {
  if (score >= 90) return 'var(--accent)';
  if (score >= 50) return '#ffa400';
  return '#ff4e42';
}
---

<div class="lighthouse-scores">
  {categories.map(({ label, score }) => {
    const offset = CIRCUMFERENCE - (score / 100) * CIRCUMFERENCE;
    const color = getColor(score);
    return (
      <div class="lighthouse-gauge" title={`${label}: ${score}`}>
        <svg width="54" height="54" viewBox="0 0 54 54" aria-hidden="true">
          <circle
            cx="27" cy="27" r={RADIUS}
            fill="none"
            stroke="var(--glass-border)"
            stroke-width="3"
          />
          <circle
            cx="27" cy="27" r={RADIUS}
            fill="none"
            stroke={color}
            stroke-width="3"
            stroke-linecap="round"
            stroke-dasharray={CIRCUMFERENCE}
            stroke-dashoffset={offset}
            transform="rotate(-90 27 27)"
          />
        </svg>
        <span class="lighthouse-value" style={`color:${color}`}>{score}</span>
        <span class="lighthouse-label">{label}</span>
      </div>
    );
  })}
</div>

<style lang="scss">
  @use '../styles/mixins' as *;

  .lighthouse-scores {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .lighthouse-gauge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    position: relative;

    svg {
      display: block;
    }
  }

  .lighthouse-value {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, calc(-50% - 8px));
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
  }

  .lighthouse-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @include respond-to(mobile) {
    .lighthouse-scores { gap: 1rem; margin-bottom: 1.25rem; }
    .lighthouse-gauge svg { width: 46px; height: 46px; }
    .lighthouse-value { transform: translate(-50%, calc(-50% - 7px)); font-size: 0.65rem; }
    .lighthouse-label { font-size: 0.55rem; }
  }

  @include respond-to(small) {
    .lighthouse-scores { gap: 0.75rem; margin-bottom: 1rem; }
    .lighthouse-gauge svg { width: 40px; height: 40px; }
    .lighthouse-value { transform: translate(-50%, calc(-50% - 6px)); font-size: 0.6rem; }
    .lighthouse-label { font-size: 0.5rem; letter-spacing: 0.03em; }
  }
</style>
