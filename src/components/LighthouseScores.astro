---
/**
 * Lighthouse Performance Scores
 * SVG circular gauges with animated stroke-draw, glow effects, and score labels.
 */
import lighthouseData from '../data/lighthouse.json';

const { scores } = lighthouseData;
const RADIUS = 26;
const CIRCUMFERENCE = 2 * Math.PI * RADIUS;

const categories = [
  { key: 'performance', label: 'Perf', score: scores.performance },
  { key: 'accessibility', label: 'A11y', score: scores.accessibility },
  { key: 'bestPractices', label: 'BP', score: scores.bestPractices },
  { key: 'seo', label: 'SEO', score: scores.seo },
] as const;

function getColor(score: number): string {
  if (score >= 90) return 'var(--accent)';
  if (score >= 50) return '#ffa400';
  return '#ff4e42';
}

function getGlowRgb(score: number): string {
  if (score >= 90) return 'var(--accent-glow)';
  if (score >= 50) return '255, 164, 0';
  return '255, 78, 66';
}
---

<div class="lighthouse-scores">
  {categories.map(({ label, score }) => {
    const offset = CIRCUMFERENCE - (score / 100) * CIRCUMFERENCE;
    const color = getColor(score);
    const glowRgb = getGlowRgb(score);
    return (
      <div class="lh-gauge" title={`${label}: ${score}/100`} data-lighthouse-gauge style={`--lh-color: ${color}; --lh-glow: ${glowRgb}`}>
        <div class="lh-ring">
          <svg width="66" height="66" viewBox="0 0 66 66" aria-hidden="true">
            <circle
              cx="33" cy="33" r={RADIUS}
              fill="none"
              stroke="rgba(var(--accent-glow), 0.06)"
              stroke-width="4"
            />
            <circle
              class="lh-arc"
              cx="33" cy="33" r={RADIUS}
              fill="none"
              stroke={color}
              stroke-width="4"
              stroke-linecap="round"
              stroke-dasharray={CIRCUMFERENCE}
              stroke-dashoffset={CIRCUMFERENCE}
              transform="rotate(-90 33 33)"
              style={`--target-offset: ${offset}`}
            />
          </svg>
          <span class="lh-value">{score}</span>
        </div>
        <span class="lh-label">{label}</span>
      </div>
    );
  })}
</div>

<style lang="scss">
  @use '../styles/mixins' as *;

  .lighthouse-scores {
    display: flex;
    justify-content: center;
    gap: 1.75rem;
    margin-bottom: 2rem;

    @include respond-to(mobile) { gap: 1.25rem; margin-bottom: 1.5rem; }
    @include respond-to(small) { gap: 0.75rem; margin-bottom: 1rem; }
  }

  .lh-gauge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    cursor: default;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);

    &:hover {
      transform: translateY(-4px) scale(1.1);

      .lh-ring {
        box-shadow: 0 0 24px rgba(var(--lh-glow), 0.3);
      }

      .lh-value {
        text-shadow: 0 0 12px var(--lh-color);
      }
    }

    @include reduced-motion {
      transition: none;
      &:hover { transform: none; }
    }
  }

  .lh-ring {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: box-shadow 0.3s ease;
  }

  .lh-arc {
    transition: stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    filter: drop-shadow(0 0 3px rgba(var(--lh-glow), 0.4));

    .lh-gauge.revealed & {
      stroke-dashoffset: var(--target-offset) !important;
    }
  }

  .lh-value {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--lh-color);
    transition: text-shadow 0.3s ease;

    @include respond-to(mobile) { font-size: 0.78rem; }
    @include respond-to(small) { font-size: 0.68rem; }
  }

  .lh-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;

    @include respond-to(mobile) { font-size: 0.55rem; }
    @include respond-to(small) { font-size: 0.48rem; }
  }

  @include respond-to(mobile) {
    .lh-ring svg { width: 54px; height: 54px; }
  }

  @include respond-to(small) {
    .lh-ring svg { width: 44px; height: 44px; }
  }
</style>

<script>
  function initLighthouseGauges() {
    const gauges = document.querySelectorAll<HTMLElement>('[data-lighthouse-gauge]');
    if (!gauges.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.3 },
    );

    for (const gauge of gauges) {
      observer.observe(gauge);
    }
  }

  document.addEventListener('astro:page-load', initLighthouseGauges);
</script>
