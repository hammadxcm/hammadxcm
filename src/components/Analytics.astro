---
/**
 * Analytics Section
 * Dashboard of GitHub, LeetCode, and StackOverflow stats.
 *
 * @depends config.github, config.leetcode?, config.stackoverflow?
 * @styles Scoped SCSS — analytics grid, images, CTA cards + responsive
 */
import SectionHeader from './SectionHeader.astro';
import ViewAllLink from './ViewAllLink.astro';
import GitHubPanel from './analytics/GitHubPanel.astro';
import ProfileViews from './analytics/ProfileViews.astro';
import AnalyticsCtaRow from './analytics/AnalyticsCtaRow.astro';
import Contribution3DGraph from './Contribution3DGraph.astro';
import { config } from '@config/index';
import { getLocaleFromUrl, localePath } from '@i18n/index';
import type { TranslationMap } from '@i18n/types';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const { username, utcOffset } = config.github;
---

<!-- ══════ ANALYTICS ══════ -->
<section id="analytics" class="section">
  <SectionHeader label={translations.analytics.label} title={translations.analytics.title} transitionId="section-analytics" />

  <GitHubPanel username={username} utcOffset={utcOffset} translations={translations} />

  <Contribution3DGraph
    id="contrib-3d"
    themeAware
    caption="3D contribution graph — regenerated daily"
    href={localePath('3d-contrib', locale)}
  />

  <ProfileViews username={username} translations={translations} />

  <AnalyticsCtaRow username={username} translations={translations} />

  <ViewAllLink href={localePath('analytics', locale)} label={translations.listing.viewAll} />
</section>

