---
/**
 * Navigation Bar
 * Fixed top navigation with responsive hamburger menu and theme switcher.
 *
 * @depends config.sections, config.site.logoText
 * @styles Scoped SCSS — nav, hamburger, theme-switcher + responsive
 */
import { config } from '@config/index';
import type { TranslationMap } from '@i18n/types';
import type { Locale } from '@i18n/types';
import { localePath } from '@i18n/index';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  translations: TranslationMap;
  locale: Locale;
  baseUrl?: string;
}

const { translations, locale, baseUrl = '' } = Astro.props;
const contrib3DHref = `${localePath('analytics', locale)}#contrib-3d`;

// Resume data for PDF export
const resumeData = {
  name: config.site.name,
  title: config.site.title,
  location: config.about.location,
  experience: config.about.experience,
  arsenal: config.about.arsenal,
  missionLog: config.about.missionLog,
  jobs: config.experience.map((e) => ({
    role: e.role,
    company: e.company,
    date: e.date,
    achievements: e.achievements,
    tags: e.tags,
  })),
  certifications: config.certifications.map((c) => ({
    name: c.name,
    issuer: c.issuer,
  })),
  socials: config.socials.map((s) => ({
    platform: s.platform,
    label: s.label,
    url: s.url,
  })),
};
---

<!-- Navigation -->
<nav transition:name="main-nav">
  <div class="nav-inner">
    <a href={baseUrl ? baseUrl : '#hero'} class="nav-logo" id="navLogo"><span id="navLogoText">{config.site.logoText}</span><span id="navLogoSuffix">{config.site.logoSuffix ?? '://hk'}</span></a>
    <ul class="nav-links" id="navLinks">
      {config.sections.map((section) => {
        const label = translations.nav.sections[section.id] || section.label;
        if (section.id === 'contributions') {
          return (
            <li class="nav-item has-submenu" data-nav-submenu>
              <a href={`${baseUrl}#${section.id}`} class="nav-submenu-trigger" aria-haspopup="true" aria-expanded="false">
                <span>{label}</span>
                <svg class="nav-submenu-caret" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </a>
              <ul class="nav-submenu" role="menu">
                <li role="none">
                  <a href={`${baseUrl}#${section.id}`} role="menuitem">Merged PRs</a>
                </li>
                <li role="none">
                  <a href={contrib3DHref} role="menuitem">3D Graph</a>
                </li>
              </ul>
            </li>
          );
        }
        return <li><a href={`${baseUrl}#${section.id}`}>{label}</a></li>;
      })}
    </ul>
    <div class="nav-actions">
      <button type="button" class="resume-btn" id="achievementTrophyBtn" aria-label="Achievements" title="Achievements (Shift+A)">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M4 1a1 1 0 0 0-1 1v1H1.5a.5.5 0 0 0-.5.5v2A2.5 2.5 0 0 0 3.5 8h.3A4.98 4.98 0 0 0 7 10.83V13H5a.5.5 0 0 0 0 1h6a.5.5 0 0 0 0-1H9v-2.17A4.98 4.98 0 0 0 12.2 8h.3A2.5 2.5 0 0 0 15 5.5v-2a.5.5 0 0 0-.5-.5H13V2a1 1 0 0 0-1-1H4ZM2.5 4H3v2.5a3 3 0 0 1-.09-.32A1.5 1.5 0 0 1 2.5 5.5V4Zm11 0v1.5a1.5 1.5 0 0 1-.41.68c-.03.11-.06.21-.09.32V4h.5Z"/>
        </svg>
      </button>
      <button type="button" class="resume-btn" id="themeRandomBtn" aria-label="Random theme" title="Random theme">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="3"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/><circle cx="16" cy="8" r="1.5" fill="currentColor"/><circle cx="8" cy="16" r="1.5" fill="currentColor"/><circle cx="16" cy="16" r="1.5" fill="currentColor"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/>
        </svg>
      </button>
      <div class="theme-switcher" id="themeSwitcher">
        <button type="button" class="theme-toggle-btn" id="themeToggleBtn" aria-label={translations.nav.switchTheme} aria-expanded="false" aria-haspopup="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        </button>
        <div class="theme-dropdown" id="themeDropdown" role="listbox" aria-label={translations.nav.selectTheme}>
          <button type="button" class="theme-option" data-theme="hacker" role="option">
            <span class="theme-swatch" style="background: #00bfbf;"></span>
            <span class="theme-label">Hacker</span>
          </button>
          <button type="button" class="theme-option" data-theme="dracula" role="option">
            <span class="theme-swatch" style="background: #BD93F9;"></span>
            <span class="theme-label">Dracula</span>
          </button>
          <button type="button" class="theme-option" data-theme="nord" role="option">
            <span class="theme-swatch" style="background: #88C0D0;"></span>
            <span class="theme-label">Nord</span>
          </button>
          <button type="button" class="theme-option" data-theme="catppuccin" role="option">
            <span class="theme-swatch" style="background: #CBA6F7;"></span>
            <span class="theme-label">Catppuccin</span>
          </button>
          <button type="button" class="theme-option" data-theme="synthwave" role="option">
            <span class="theme-swatch" style="background: #FF2E97;"></span>
            <span class="theme-label">Synthwave</span>
          </button>
          <button type="button" class="theme-option" data-theme="matrix" role="option">
            <span class="theme-swatch" style="background: #00FF41;"></span>
            <span class="theme-label">Matrix</span>
          </button>
          <button type="button" class="theme-option" data-theme="bloodmoon" role="option">
            <span class="theme-swatch" style="background: #FF0040;"></span>
            <span class="theme-label">Blood Moon</span>
          </button>
          <button type="button" class="theme-option" data-theme="midnight" role="option">
            <span class="theme-swatch" style="background: #7B73FF;"></span>
            <span class="theme-label">Midnight</span>
          </button>
          <button type="button" class="theme-option" data-theme="arctic" role="option">
            <span class="theme-swatch" style="background: #0369A1; border: 1px solid rgba(0,0,0,0.15);"></span>
            <span class="theme-label">Arctic Light</span>
          </button>
          <button type="button" class="theme-option" data-theme="gruvbox" role="option">
            <span class="theme-swatch" style="background: #FABD2F;"></span>
            <span class="theme-label">Gruvbox</span>
          </button>
          <button type="button" class="theme-option" data-theme="cyberpunk" role="option">
            <span class="theme-swatch" style="background: #FFD700;"></span>
            <span class="theme-label">Cyberpunk</span>
          </button>
          <button type="button" class="theme-option" data-theme="nebula" role="option">
            <span class="theme-swatch" style="background: #E040FB;"></span>
            <span class="theme-label">Nebula</span>
          </button>
          <button type="button" class="theme-option" data-theme="solarized" role="option">
            <span class="theme-swatch" style="background: #268BD2;"></span>
            <span class="theme-label">Solarized</span>
          </button>
          <button type="button" class="theme-option" data-theme="rosepine" role="option">
            <span class="theme-swatch" style="background: #EA9A97;"></span>
            <span class="theme-label">Ros&eacute; Pine</span>
          </button>
          <button type="button" class="theme-option" data-theme="monokai" role="option">
            <span class="theme-swatch" style="background: #A6E22E;"></span>
            <span class="theme-label">Monokai</span>
          </button>
        </div>
      </div>
      <LanguageSwitcher locale={locale} translations={translations} />
      <button type="button" class="hamburger" id="hamburger" aria-label={translations.nav.toggleMenu}>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<script type="application/json" id="resumeData" set:html={JSON.stringify(resumeData)} />

<script>
  const MOBILE_BREAKPOINT = 768;
  const isMobile = () => window.matchMedia(`(max-width: ${MOBILE_BREAKPOINT}px)`).matches;
  const items = document.querySelectorAll<HTMLLIElement>('[data-nav-submenu]');

  for (const item of items) {
    const trigger = item.querySelector<HTMLAnchorElement>('.nav-submenu-trigger');
    if (!trigger) continue;

    trigger.addEventListener('click', (e) => {
      if (!isMobile()) return;
      e.preventDefault();
      const open = item.classList.toggle('open');
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    trigger.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter' && e.key !== ' ' && e.key !== 'ArrowDown') return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        item.querySelector<HTMLAnchorElement>('.nav-submenu a')?.focus();
      }
    });
  }

  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    for (const item of items) {
      if (!item.contains(target)) {
        item.classList.remove('open');
        item.querySelector('.nav-submenu-trigger')?.setAttribute('aria-expanded', 'false');
      }
    }
  });
</script>

<style lang="scss">
  @use '../styles/mixins' as *;

  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    padding: 0 2rem;
    @include backdrop-blur(var(--blur-backdrop));
    background: var(--glass-bg);
    border-bottom: 1px solid var(--glass-border);
    transition: transform var(--duration-normal), background var(--duration-normal);

    @include respond-to(mobile) {
      padding: 0 1.25rem;
      @include backdrop-blur(blur(10px));
      will-change: transform;
    }
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 13ch;
    overflow: hidden;
    transition: filter var(--duration-normal);
    animation: navLogoGlow 4s ease-in-out infinite;
    will-change: filter;

    &:hover {
      filter: drop-shadow(0 0 6px var(--accent)) drop-shadow(0 0 12px var(--accent));
    }

    #navLogoSuffix {
      color: var(--text-dim);
      transition: opacity 150ms ease;

      &.fade-out { opacity: 0; }
    }
  }

  @keyframes navLogoGlow {
    0%, 100% { filter: drop-shadow(0 0 0px transparent); }
    50% { filter: drop-shadow(0 0 4px var(--accent)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-logo { animation: none; }
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;

    a {
      color: var(--text-dim);
      font-size: 0.875rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      transition: color var(--duration-normal);

      &:hover { color: var(--accent); }
    }

    @include respond-to(mobile) {
      position: fixed;
      top: 64px;
      left: 0; right: 0;
      background: var(--bg-card-solid);
      @include backdrop-blur(blur(10px));
      will-change: transform;
      flex-direction: column;
      padding: 1.5rem 2rem 2rem;
      gap: 0.25rem;
      border-bottom: 1px solid var(--glass-border);
      transform: translateY(-100%);
      opacity: 0;
      pointer-events: none;
      transition: all var(--duration-normal);

      &.open {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
      }

      li { padding: 0.5rem 0; }
      a { font-size: 1rem; }
    }
  }

  .nav-item.has-submenu {
    position: relative;
  }

  .nav-submenu-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    cursor: pointer;
  }

  .nav-submenu-caret {
    transition: transform var(--duration-normal) var(--ease-out-expo);
    opacity: 0.7;
  }

  .nav-submenu {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 180px;
    list-style: none;
    background: var(--bg-card-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.4rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    opacity: 0;
    visibility: hidden;
    z-index: 9999;
    transition: opacity 0.2s var(--ease-out-expo), transform 0.2s var(--ease-out-expo), visibility 0.2s;

    li { margin: 0; padding: 0; }

    a {
      display: block;
      padding: 0.55rem 0.8rem;
      border-radius: 8px;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--text);
      white-space: nowrap;

      &:hover,
      &:focus-visible {
        background: var(--glass-bg);
        color: var(--accent);
      }
    }
  }

  .nav-item.has-submenu:hover,
  .nav-item.has-submenu:focus-within,
  .nav-item.has-submenu.open {
    .nav-submenu {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
    .nav-submenu-caret {
      transform: rotate(180deg);
    }
  }

  @include respond-to(mobile) {
    .nav-submenu {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      min-width: 0;
      margin-top: 0.4rem;
      margin-left: 1rem;
      padding: 0.3rem 0;
      border: none;
      background: transparent;
      box-shadow: none;
      display: none;
    }

    .nav-item.has-submenu.open .nav-submenu {
      display: block;
    }

    .nav-submenu a { font-size: 0.95rem; }
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 10px;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;

    span {
      width: 24px;
      height: 2px;
      background: var(--text);
      border-radius: 2px;
      transition: all var(--duration-normal);
    }

    &.active {
      span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
      span:nth-child(2) { opacity: 0; }
      span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
    }

    @include respond-to(mobile) { display: flex; }
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .resume-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all var(--duration-normal);

    &:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    &.loading {
      opacity: 0.5;
      pointer-events: none;
    }

    svg { width: 16px; height: 16px; }

    @include respond-to(mobile) { min-width: 44px; min-height: 44px; }
  }

  .theme-switcher {
    position: relative;
  }

  .theme-toggle-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all var(--duration-normal);

    &:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    svg { width: 18px; height: 18px; }

    @include respond-to(mobile) { min-width: 44px; min-height: 44px; }
  }

  .theme-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 180px;
    background: var(--bg-card-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.5rem;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s var(--ease-out-expo);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    max-height: 400px;
    overflow-y: auto;

    &.open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
  }

  .theme-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.2s;

    &:hover { background: var(--glass-bg); }

    &.active {
      background: var(--glass-bg);
      color: var(--accent);

      .theme-swatch {
        box-shadow: 0 0 0 2px var(--bg-card-solid), 0 0 0 4px var(--accent);
      }
    }
  }

  .theme-swatch {
    width: 16px;
    height: 16px;
    border-radius: var(--radius-full);
    flex-shrink: 0;
  }

  .theme-label {
    white-space: nowrap;
  }
</style>
