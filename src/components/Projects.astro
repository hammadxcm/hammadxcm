---
/**
 * Open Source Projects Section
 * Shows featured (config) projects first, then dynamically fetched GitHub repos.
 * Initial 6 visible, "View More" expands to show all.
 *
 * @depends config.projects, projects.json, ArrowIcon, SectionHeader
 * @styles Scoped SCSS — project grid, cards, tags, View More + responsive
 */
import SectionHeader from './SectionHeader.astro';
import ViewAllLink from './ViewAllLink.astro';
import ArrowIcon from './ArrowIcon.astro';
import StarIcon from './icons/StarIcon.astro';
import ForkIcon from './icons/ForkIcon.astro';
import DownloadIcon from './icons/DownloadIcon.astro';
import { getLangColor } from '@config/lang-colors';
import { formatStars, formatDownloads } from '../utils/format';
import { sanitizeHtml } from '@utils/sanitize';
import type { TranslationMap } from '@i18n/types';
import { getLocaleFromUrl, localePath } from '@i18n/index';
import { getProjectData } from '../utils/project-data';
import { resolveRepoIcon } from '../utils/project-icons';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const { featured, dynamicRepos, downloadCounts } = getProjectData();

const INITIAL_SHOW = 6;
const totalCount = featured.length + dynamicRepos.length;
const hasMore = totalCount > INITIAL_SHOW;
---

<!-- ══════ OPEN SOURCE ══════ -->
<section id="projects" class="section">
  <SectionHeader label={translations.projects.label} title={translations.projects.title} />
  <div class="projects-grid stagger" id="projects-grid">
    {/* Featured projects from config */}
    {featured.map((project, idx) => {
      const hidden = hasMore && idx >= INITIAL_SHOW;
      const pkgKey = project.npmPackage || project.gemName || '';
      const dlCount = pkgKey ? (downloadCounts[pkgKey] || 0) : 0;
      return (
        <div class:list={['project-card', 'glass', 'reveal', 'glow-border', { 'project-hidden': hidden }]} data-tilt>
          <div class="project-icon">
            <img
              src={project.iconIsLocal ? `${base}${project.icon}` : project.icon}
              alt={project.name}
              width="44"
              height="44"
            />
          </div>
          {dlCount > 0 && (
            <div class="project-header-row">
              <span class="project-downloads">
                <DownloadIcon />
                {formatDownloads(dlCount)}
              </span>
            </div>
          )}
          <h3 class="project-name">
            <a href={project.url} target="_blank" rel="noopener noreferrer">{project.name}</a>
          </h3>
          <p class="project-desc" set:html={sanitizeHtml(project.description)} />
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span>{tag}</span>
            ))}
          </div>
          <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link">
            {project.linkText} <ArrowIcon />
          </a>
        </div>
      );
    })}

    {/* Dynamic repos from GitHub */}
    {dynamicRepos.map((repo, idx) => {
      const globalIdx = featured.length + idx;
      const hidden = hasMore && globalIdx >= INITIAL_SHOW;
      const dotColor = repo.language ? getLangColor(repo.language) : null;
      return (
        <a
          class:list={['project-card', 'project-card--dynamic', 'glass', 'reveal', 'glow-border', { 'project-hidden': hidden }]}
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          data-tilt
        >
          <div class="project-icon">
            <img src={resolveRepoIcon(repo, base)} alt={repo.name} width="44" height="44" loading="lazy" />
          </div>
          <div class="project-header-row">
            {repo.language && dotColor && (
              <span class="project-lang">
                <span class="lang-dot" style={`background:${dotColor}`} />
                {repo.language}
              </span>
            )}
            <span class="project-stars">
              <StarIcon />
              {formatStars(repo.stars)}
            </span>
            {repo.forks > 0 && (
              <span class="project-forks">
                <ForkIcon />
                {repo.forks}
              </span>
            )}
          </div>
          <h3 class="project-name">{repo.name}</h3>
          {repo.description && (
            <p class="project-desc">{repo.description}</p>
          )}
          {repo.topics.length > 0 && (
            <div class="project-tags">
              {repo.topics.slice(0, 5).map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          )}
          <span class="project-link">
            {translations.projects.viewRepo} <ArrowIcon />
          </span>
        </a>
      );
    })}
  </div>

  {hasMore && (
    <ViewAllLink href={localePath('projects', locale)} label={translations.listing.viewAll} count={totalCount} />
  )}
</section>

<style lang="scss">
  @use '../styles/mixins' as *;
  @use '../styles/utilities/tag' as *;

  .projects-grid {
    @include responsive-grid;
  }

  .project-card {
    @include card-padding;
    transition: all var(--duration-slow) var(--ease-out-expo);
    transform-style: preserve-3d;
    perspective: 1000px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  .project-card--dynamic {
    text-decoration: none;
    color: var(--text);
  }

  .project-icon {
    font-size: 2rem;
    margin-bottom: 1rem;

    img {
      width: 44px; height: 44px;
      object-fit: contain;
    }
  }

  .project-header-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
  }

  .project-lang {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .lang-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .project-stars,
  .project-forks,
  .project-downloads {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    opacity: 0.85;

    :global(svg) { opacity: 0.7; }
  }

  .project-name {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;

    a {
      color: var(--text);
      transition: color var(--duration-normal);
      &:hover { color: var(--accent); }
    }
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;

    @include respond-to(mobile) { font-size: 0.85rem; }
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;

    span {
      @include tag;
    }
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 1rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);

    &:hover { color: var(--accent-mint); }

    :global(svg) { width: 16px; height: 16px; }
  }

  /* ── Hidden Cards ── */
  .project-hidden {
    display: none !important;
  }

</style>
