---
/**
 * Open Source Projects Section
 * Shows top 6 projects sorted by downloads, then stars.
 * "View All" links to the full listing page.
 *
 * @depends config.projects, projects.json, ArrowIcon, SectionHeader
 * @styles Scoped SCSS — project grid, cards, tags, View More + responsive
 */
import SectionHeader from './SectionHeader.astro';
import ViewAllLink from './ViewAllLink.astro';
import FeaturedProjectCard from './cards/FeaturedProjectCard.astro';
import DynamicRepoCard from './cards/DynamicRepoCard.astro';
import type { TranslationMap } from '@i18n/types';
import { getLocaleFromUrl, localePath } from '@i18n/index';
import { getProjectData } from '../utils/project-data';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const { projects } = getProjectData();

const INITIAL_SHOW = 6;
const visible = projects.slice(0, INITIAL_SHOW);
const totalCount = projects.length;
const hasMore = totalCount > INITIAL_SHOW;
---

<!-- ══════ OPEN SOURCE ══════ -->
<section id="projects" class="section">
  <SectionHeader label={translations.projects.label} title={translations.projects.title} transitionId="section-projects" />
  <div class="projects-grid stagger" id="projects-grid">
    {visible.map((item) =>
      item.kind === 'featured' ? (
        <FeaturedProjectCard
          project={item.project}
          dlCount={item.downloads}
          base={base}
        />
      ) : (
        <DynamicRepoCard
          repo={item.repo}
          base={base}
          viewRepoLabel={translations.projects.viewRepo}
        />
      )
    )}
  </div>

  {hasMore && (
    <ViewAllLink href={localePath('projects', locale)} label={translations.listing.viewAll} count={totalCount} />
  )}
</section>

<style lang="scss" is:global>
  @use '../styles/mixins' as *;
  @use '../styles/utilities/project-card' as *;

  #projects {
    @include project-card-base;

    .projects-grid {
      @include responsive-grid;
    }

    .project-card {
      transform-style: preserve-3d;
      perspective: 1000px;
    }

    .project-hidden {
      display: none !important;
    }
  }
</style>
