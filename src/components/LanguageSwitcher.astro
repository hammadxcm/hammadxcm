---
/**
 * Language Switcher
 * Globe icon button + dropdown for switching locales.
 * Same visual pattern as the theme switcher.
 */
import type { Locale, TranslationMap } from '@i18n/types';
import { LOCALES, localePath } from '@i18n/index';

interface Props {
  locale: Locale;
  translations: TranslationMap;
}

const { locale, translations } = Astro.props;

const localeNames: Record<Locale, { code: string; name: string }> = {
  en: { code: 'EN', name: 'English' },
  es: { code: 'ES', name: 'Español' },
  fr: { code: 'FR', name: 'Français' },
  ar: { code: 'AR', name: 'العربية' },
  ur: { code: 'UR', name: 'اردو' },
  fa: { code: 'FA', name: 'فارسی' },
  zh: { code: 'ZH', name: '中文' },
  hi: { code: 'HI', name: 'हिन्दी' },
  de: { code: 'DE', name: 'Deutsch' },
  bn: { code: 'BN', name: 'বাংলা' },
  pt: { code: 'PT', name: 'Português' },
  ru: { code: 'RU', name: 'Русский' },
  id: { code: 'ID', name: 'Indonesia' },
};
---

<div class="lang-switcher-wrap" id="langSwitcherWrap">
  <button
    type="button"
    class="lang-toggle-btn"
    id="langToggleBtn"
    aria-label={translations.nav.switchLanguage}
    aria-expanded="false"
    aria-haspopup="true"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <path d="M2 12h20"/>
      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
    </svg>
  </button>
  <div class="lang-dropdown" id="langDropdown" role="listbox" aria-label={translations.nav.switchLanguage}>
    {LOCALES.map((l) => (
      <a
        href={localePath('', l)}
        class:list={['lang-option', { active: l === locale }]}
        role="option"
        aria-selected={l === locale ? 'true' : 'false'}
      >
        <span class="lang-code">{localeNames[l].code}</span>
        <span class="lang-name">{localeNames[l].name}</span>
      </a>
    ))}
  </div>
</div>

<style lang="scss">
  .lang-switcher-wrap {
    position: relative;
  }

  .lang-toggle-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all var(--duration-normal);

    &:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    svg { width: 18px; height: 18px; }
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 160px;
    background: var(--bg-card-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.5rem;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s var(--ease-out-expo);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);

    [dir="rtl"] & {
      right: auto;
      left: 0;
    }

    &.open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
  }

  .lang-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;

    &:hover { background: var(--glass-bg); }

    &.active {
      background: var(--glass-bg);
      color: var(--accent);
    }
  }

  .lang-code {
    font-weight: 600;
    font-size: 0.75rem;
    min-width: 2ch;
  }

  .lang-name {
    white-space: nowrap;
  }
</style>
