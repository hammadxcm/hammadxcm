---
/**
 * Contributions Summary Stats Banner
 * Dashboard-style grid cards with glow halos.
 */
import { getLangColor } from '@config/lang-colors';
import { formatStars } from '../utils/format';
import type { ContributionPR } from '@config/types';
import type { TranslationMap } from '@i18n/types';

interface Props {
  prs: ContributionPR[];
  translations: TranslationMap;
}

const { prs, translations } = Astro.props;

const mergedCount = prs.filter((pr) => pr.state === 'merged').length;
const openCount = prs.filter((pr) => pr.state === 'open').length;
const closedCount = prs.filter((pr) => pr.state === 'closed').length;
const uniqueOrgs = new Set(prs.map((pr) => pr.repo.fullName.split('/')[0])).size;
const uniqueRepos = new Set(prs.map((pr) => pr.repo.fullName)).size;
const combinedStars = [...new Map(prs.map((pr) => [pr.repo.fullName, pr.repo.stars])).values()].reduce((a, b) => a + b, 0);
const totalAdditions = prs.reduce((sum, pr) => sum + (pr.additions || 0), 0);
const totalDeletions = prs.reduce((sum, pr) => sum + (pr.deletions || 0), 0);
const uniqueLangs = [...new Set(prs.map((pr) => pr.repo.language).filter(Boolean))] as string[];

interface StatItem {
  value: string;
  label: string;
  accent?: boolean;
}

const statItems: StatItem[] = [
  { value: String(mergedCount), label: translations.contributions.prsMerged, accent: true },
  { value: String(uniqueOrgs), label: translations.contributions.orgs },
  { value: String(uniqueRepos), label: translations.contributions.repos },
  { value: formatStars(combinedStars), label: translations.contributions.combinedStars },
];

if (openCount > 0) {
  statItems.push({ value: String(openCount), label: translations.contributions.prsOpen });
}
if (closedCount > 0) {
  statItems.push({ value: String(closedCount), label: translations.contributions.prsClosed });
}

statItems.push(
  { value: `+${totalAdditions.toLocaleString()} / -${totalDeletions.toLocaleString()}`, label: translations.contributions.linesChanged },
  { value: `${uniqueLangs.length}`, label: translations.contributions.languages },
);
---

<div class="contrib-summary dash-hero-stats reveal">
  {statItems.map((stat) => (
    <div class="dash-hero-stat glass">
      <span
        class:list={['dash-hero-value', 'summary-val', { 'summary-val--diff': stat.label === translations.contributions.linesChanged }]}
        data-count-target={/^\d+$/.test(stat.value) ? stat.value : undefined}
      >
        {stat.label === translations.contributions.languages ? (
          <>
            {stat.value}
            <span class="lang-dots">
              {uniqueLangs.slice(0, 6).map((lang) => (
                <span class="summary-lang-dot" style={`background:${getLangColor(lang)}`} title={lang} />
              ))}
            </span>
          </>
        ) : stat.value}
      </span>
      <span class="dash-hero-label">{stat.label}</span>
    </div>
  ))}
</div>

<style lang="scss">
  @use '../styles/mixins' as *;

  .contrib-summary {
    margin-bottom: 2rem;
  }

  .summary-val {
    font-size: 2rem;

    @include respond-to(mobile) {
      font-size: 1.5rem;
    }

    @include respond-to(small) {
      font-size: 1.25rem;
    }

    &--diff {
      font-size: 1.1rem;
      @include respond-to(mobile) { font-size: 0.95rem; }
    }
  }

  .lang-dots {
    display: inline-flex;
    gap: 0.3rem;
    align-items: center;
    margin-inline-start: 0.5rem;
    vertical-align: middle;
  }

  .summary-lang-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>
