---
/**
 * About Section
 * Terminal-styled code card showing personal/professional details
 * with copy-to-clipboard and multi-language switching.
 *
 * @depends config.about, about-builder
 * @styles Scoped SCSS — code card, syntax highlighting, lang switcher + responsive
 */
import SectionHeader from './SectionHeader.astro';
import { config } from '@config/index';
import { buildAboutLines, buildAboutMultiLang } from '@config/about-builder';
import { sanitizeHtml } from '@utils/sanitize';
import type { TranslationMap } from '@i18n/types';

interface Props {
  translations: TranslationMap;
}

const { translations } = Astro.props;
const { displayLines, copyLines } = buildAboutLines(config.about);
const codeString = copyLines.join('\n');
const multiLangData = buildAboutMultiLang(config.about);
---

<!-- ══════ ABOUT ══════ -->
<section id="about" class="section">
  <SectionHeader label={translations.about.label} title={translations.about.title} />
  <div class="about-card glass reveal-scale">
    <div class="code-header">
      <span class="code-dot red"></span>
      <span class="code-dot yellow"></span>
      <span class="code-dot green"></span>
      <span class="code-filename" id="aboutFilename">{translations.about.filename}</span>
      <select class="lang-switcher" id="langSwitcher" aria-label={translations.about.selectLanguage}>
        <option value="bash">Bash</option>
        <option value="python">Python</option>
        <option value="ruby">Ruby</option>
        <option value="javascript">JavaScript</option>
        <option value="typescript">TypeScript</option>
        <option value="java">Java</option>
        <option value="cpp">C++</option>
        <option value="go">Go</option>
        <option value="rust">Rust</option>
        <option value="php">PHP</option>
        <option value="perl">Perl</option>
        <option value="csharp">C#</option>
        <option value="swift">Swift</option>
        <option value="kotlin">Kotlin</option>
        <option value="cobol">COBOL</option>
        <option value="fortran">Fortran</option>
        <option value="assembly">Assembly</option>
        <option value="binary">Binary</option>
      </select>
      <button type="button" class="code-copy" id="copyBtn" data-code={codeString} data-label-copy={translations.about.copy} data-label-copied={translations.about.copied} aria-label={translations.a11y.copyCode}>
        <svg id="copyIcon" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        <span id="copyLabel">{translations.about.copy}</span>
      </button>
      <button type="button" class="code-copy" id="resumeExportBtn" aria-label={translations.resume.download} title={translations.resume.download}>
        <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        <span>{translations.resume.download}</span>
      </button>
    </div>
    <div class="code-body" id="aboutCodeBody">
{displayLines.map((line, i) => (
<span class="code-line" data-about={i === 2 ? 'comment' : i === displayLines.length - 1 ? 'echo' : undefined}><span class="code-line-num">{i + 1}</span><Fragment set:html={sanitizeHtml(line)} /></span>
))}
    </div>
  </div>
  <script type="application/json" id="aboutMultiLangData" set:html={JSON.stringify(multiLangData)} />
</section>

<style lang="scss">
  @use '../styles/mixins' as *;

  .about-card {
    max-width: 800px;
    margin: 0 auto;
    overflow: hidden;
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 1rem 1.5rem;
    background: var(--glass-bg);
    border-bottom: 1px solid var(--glass-border);

    @include respond-to(mobile) {
      flex-wrap: wrap;
      padding: 0.75rem 1rem;
      gap: 6px;
    }
  }

  .code-dot {
    width: 12px; height: 12px;
    border-radius: var(--radius-full);

    &.red { background: #ff5f57; }
    &.yellow { background: #febc2e; }
    &.green { background: #28c840; }

    @include respond-to(mobile) { display: none; }
  }

  .code-filename {
    margin-inline-start: auto;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);

    @include respond-to(mobile) {
      margin-inline-start: 0;
      font-size: 0.72rem;
    }
  }

  .lang-switcher {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: all var(--duration-normal);
    appearance: auto;

    &:hover, &:focus {
      border-color: var(--accent);
      color: var(--accent);
      outline: none;
    }

    option {
      background: var(--bg-card-solid);
      color: var(--text);
    }

    @include respond-to(small) {
      font-size: 0.65rem;
      padding: 0.2rem 0.35rem;
    }
  }

  .code-copy {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-inline-start: 0.75rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    cursor: pointer;
    transition: all var(--duration-normal);

    &:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(var(--accent-glow), 0.06);
    }

    &.copied {
      border-color: var(--code-success);
      color: var(--code-success);
    }

    &.loading {
      opacity: 0.5;
      pointer-events: none;
    }

    svg {
      width: 14px; height: 14px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    @include respond-to(mobile) {
      margin-inline-start: 0.25rem;
      padding: 0.25rem 0.5rem;
    }

    @include respond-to(small) {
      gap: 0;

      span { display: none; }
    }
  }

  .code-body {
    padding: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.8;
    overflow-x: auto;

    :global(.keyword) { color: var(--code-keyword); }
    :global(.const) { color: var(--code-const); }
    :global(.string) { color: var(--code-string); }
    :global(.property) { color: var(--accent-mint); }
    :global(.bracket) { color: var(--code-bracket); }
    :global(.comment) { color: var(--code-comment); font-style: italic; }

    @include respond-to(mobile) {
      font-size: 0.7rem;
      line-height: 1.6;
      padding: 1rem;

      :global(.code-line) {
        white-space: pre-wrap;
        word-break: break-word;
      }
    }

    @include respond-to(small) {
      font-size: 0.65rem;
      padding: 0.75rem;
      overflow-x: auto;
    }
  }

  :global(.code-line) {
    display: block;
    padding-inline-start: 2rem;
    white-space: pre;
  }

  :global(.code-line-num) {
    display: inline-block;
    width: 2rem;
    margin-inline-start: -2rem;
    color: var(--code-line-num);
    text-align: end;
    padding-inline-end: 1rem;
    user-select: none;
  }
</style>
