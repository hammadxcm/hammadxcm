---
/**
 * 3D Contribution Graph
 * Embeds the yoshi389111/github-profile-3d-contrib SVG generated by the
 * "Profile 3D Contrib" GitHub Actions workflow. Source of truth is the
 * committed file at /generated/profile-3d-contrib/. A prebuild step mirrors
 * those SVGs into /public/generated/ so Astro can serve them.
 *
 * When themeAware is true, the component uses the green-animate variant
 * as a neutral base and applies a per-theme `hue-rotate` + `saturate`
 * CSS filter so the graph colors track the active theme accent. The
 * filter values are defined alongside every theme in themes/_themes.scss
 * (--contrib-3d-hue, --contrib-3d-sat). No JS is needed; the browser
 * re-paints instantly when data-theme flips.
 */
interface Props {
  id?: string;
  variant?: string;
  caption?: string;
  href?: string;
  eager?: boolean;
  themeAware?: boolean;
}

const {
  id,
  variant,
  caption,
  href,
  eager = false,
  themeAware = false,
} = Astro.props;

const effectiveVariant = variant ?? 'profile-green-animate';
const src = `/generated/profile-3d-contrib/${effectiveVariant}.svg`;
const altText = caption ?? '3D contribution graph';
const figureClass = themeAware ? 'contrib-3d contrib-3d--themed' : 'contrib-3d';
---

<figure class:list={[figureClass]} id={id}>
  {href ? (
    <a href={href} class="contrib-3d-link" aria-label={altText}>
      <img
        src={src}
        alt={altText}
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        width="900"
        height="300"
      />
    </a>
  ) : (
    <img
      src={src}
      alt={altText}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      width="900"
      height="300"
    />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style lang="scss">
  @use '../styles/mixins' as *;

  .contrib-3d {
    margin: var(--space-xl) 0 0;
    padding: var(--space-lg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    @include backdrop-blur;
    overflow-x: auto;
    text-align: center;
  }

  .contrib-3d-link {
    display: block;
    transition: transform var(--duration-normal) var(--ease-out-expo);

    &:hover,
    &:focus-visible {
      transform: translateY(-2px);
    }
  }

  .contrib-3d img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }

  .contrib-3d--themed img {
    filter:
      hue-rotate(var(--contrib-3d-hue, 0deg))
      saturate(var(--contrib-3d-sat, 1))
      brightness(var(--contrib-3d-bright, 1));
    transition: filter var(--duration-normal) var(--ease-out-expo);
  }

  figcaption {
    margin-top: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  @include respond-to(mobile) {
    .contrib-3d {
      padding: var(--space-md);
    }
  }
</style>
