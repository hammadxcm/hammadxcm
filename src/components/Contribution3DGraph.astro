---
/**
 * 3D Contribution Graph
 * Embeds the yoshi389111/github-profile-3d-contrib SVG generated by the
 * "Profile 3D Contrib" GitHub Actions workflow. Source of truth is the
 * committed file at /generated/profile-3d-contrib/. A prebuild step mirrors
 * those SVGs into /public/generated/ so Astro can serve them.
 */
interface Props {
  variant?: string;
  caption?: string;
  href?: string;
  eager?: boolean;
}

const {
  variant = 'profile-green-animate',
  caption,
  href,
  eager = false,
} = Astro.props;

const src = `/generated/profile-3d-contrib/${variant}.svg`;
---

<figure class="contrib-3d">
  {href ? (
    <a href={href} class="contrib-3d-link" aria-label={caption ?? '3D contribution graph'}>
      <img
        src={src}
        alt={caption ?? '3D contribution graph'}
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        width="900"
        height="300"
      />
    </a>
  ) : (
    <img
      src={src}
      alt={caption ?? '3D contribution graph'}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      width="900"
      height="300"
    />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style lang="scss">
  @use '../styles/mixins' as *;

  .contrib-3d {
    margin: var(--space-xl) 0 0;
    padding: var(--space-lg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    @include backdrop-blur;
    overflow-x: auto;
    text-align: center;
  }

  .contrib-3d-link {
    display: block;
    transition: transform var(--duration-normal) var(--ease-out-expo);

    &:hover,
    &:focus-visible {
      transform: translateY(-2px);
    }
  }

  .contrib-3d img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }

  figcaption {
    margin-top: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  @include respond-to(mobile) {
    .contrib-3d {
      padding: var(--space-md);
    }
  }
</style>
