---
/**
 * 3D Contribution Graph
 * Embeds the yoshi389111/github-profile-3d-contrib SVG generated by the
 * "Profile 3D Contrib" GitHub Actions workflow. Source of truth is the
 * committed file at /generated/profile-3d-contrib/. A prebuild step mirrors
 * those SVGs into /public/generated/ so Astro can serve them.
 *
 * When themeAware is true, the initial variant is chosen from the site's
 * default theme (SSR) and a small inline script swaps the src whenever the
 * user changes theme (mutation on data-theme attribute).
 */
import { config } from '@config/index';
import { contribution3DVariantMap, getContribution3DVariant } from '../scripts/theme-data/contribution-3d';

interface Props {
  variant?: string;
  caption?: string;
  href?: string;
  eager?: boolean;
  themeAware?: boolean;
}

const {
  variant,
  caption,
  href,
  eager = false,
  themeAware = false,
} = Astro.props;

const defaultTheme = config.site.theme || 'hacker';
const initialVariant = variant ?? (themeAware ? getContribution3DVariant(defaultTheme) : 'profile-green-animate');
const src = `/generated/profile-3d-contrib/${initialVariant}.svg`;
const altText = caption ?? '3D contribution graph';
const variantMapJson = themeAware ? JSON.stringify(contribution3DVariantMap) : undefined;
---

<figure class="contrib-3d" data-theme-aware={themeAware ? 'true' : undefined} data-variant-map={variantMapJson}>
  {href ? (
    <a href={href} class="contrib-3d-link" aria-label={altText}>
      <img
        src={src}
        alt={altText}
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        width="900"
        height="300"
        data-contrib-3d-img={themeAware ? 'true' : undefined}
      />
    </a>
  ) : (
    <img
      src={src}
      alt={altText}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      width="900"
      height="300"
      data-contrib-3d-img={themeAware ? 'true' : undefined}
    />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

{themeAware && (
  <script is:inline>
    {`
    (function () {
      var root = document.querySelector('.contrib-3d[data-theme-aware="true"]');
      if (!root) return;
      var raw = root.getAttribute('data-variant-map');
      if (!raw) return;
      var map;
      try { map = JSON.parse(raw); } catch (_) { return; }
      var imgs = document.querySelectorAll('img[data-contrib-3d-img="true"]');

      function pick(theme) {
        return (theme && map[theme]) || map.hacker;
      }
      function apply(theme) {
        var variant = pick(theme);
        var next = '/generated/profile-3d-contrib/' + variant + '.svg';
        imgs.forEach(function (img) {
          if (img.src.indexOf(next) === -1) img.src = next;
        });
      }

      apply(document.documentElement.getAttribute('data-theme'));

      var obs = new MutationObserver(function (mutations) {
        for (var i = 0; i < mutations.length; i++) {
          if (mutations[i].attributeName === 'data-theme') {
            apply(document.documentElement.getAttribute('data-theme'));
            return;
          }
        }
      });
      obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    })();
    `}
  </script>
)}

<style lang="scss">
  @use '../styles/mixins' as *;

  .contrib-3d {
    margin: var(--space-xl) 0 0;
    padding: var(--space-lg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    @include backdrop-blur;
    overflow-x: auto;
    text-align: center;
  }

  .contrib-3d-link {
    display: block;
    transition: transform var(--duration-normal) var(--ease-out-expo);

    &:hover,
    &:focus-visible {
      transform: translateY(-2px);
    }
  }

  .contrib-3d img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }

  figcaption {
    margin-top: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  @include respond-to(mobile) {
    .contrib-3d {
      padding: var(--space-md);
    }
  }
</style>
