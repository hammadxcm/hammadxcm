---
/**
 * 3D Contribution Graph
 * Embeds the yoshi389111/github-profile-3d-contrib SVG generated by the
 * "Profile 3D Contrib" GitHub Actions workflow. Source of truth is the
 * committed file at /generated/profile-3d-contrib/. A prebuild step
 * mirrors those SVGs into /public/generated/ so Astro can serve them.
 *
 * When themeAware is true, the component picks between a dark-mode and
 * light-mode SVG variant based on the active `data-theme`, and additionally
 * applies a per-theme CSS hue-rotate / saturate / brightness filter so the
 * accent color tracks the theme. Dark themes load the dark variant, light
 * themes (currently just `arctic`) load the light variant. A small inline
 * script swaps the `<img src>` whenever the user changes theme.
 */
import { config } from '@config/index';

interface Props {
  id?: string;
  variant?: string;
  lightVariant?: string;
  darkVariant?: string;
  caption?: string;
  href?: string;
  eager?: boolean;
  themeAware?: boolean;
}

const {
  id,
  variant,
  lightVariant = 'profile-green-animate',
  darkVariant = 'profile-night-green',
  caption,
  href,
  eager = false,
  themeAware = false,
} = Astro.props;

const LIGHT_THEMES = ['arctic'];

const defaultTheme = config.site.theme || 'hacker';
const initialVariant =
  variant ??
  (themeAware
    ? LIGHT_THEMES.includes(defaultTheme)
      ? lightVariant
      : darkVariant
    : 'profile-green-animate');

const src = `/generated/profile-3d-contrib/${initialVariant}.svg`;
const altText = caption ?? '3D contribution graph';
const figureClass = themeAware ? 'contrib-3d contrib-3d--themed' : 'contrib-3d';
---

<figure
  class:list={[figureClass]}
  id={id}
  data-theme-aware={themeAware ? 'true' : undefined}
  data-variant-light={themeAware ? lightVariant : undefined}
  data-variant-dark={themeAware ? darkVariant : undefined}
>
  {href ? (
    <a href={href} class="contrib-3d-link" aria-label={altText}>
      <img
        src={src}
        alt={altText}
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        width="900"
        height="300"
        data-contrib-3d-img={themeAware ? 'true' : undefined}
      />
    </a>
  ) : (
    <img
      src={src}
      alt={altText}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      width="900"
      height="300"
      data-contrib-3d-img={themeAware ? 'true' : undefined}
    />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

{themeAware && (
  <script is:inline>
    {`
    (function () {
      if (window.__contrib3dInit) return;
      window.__contrib3dInit = true;

      var root = document.querySelector('.contrib-3d[data-theme-aware="true"]');
      if (!root) return;
      var darkVariant = root.getAttribute('data-variant-dark');
      var lightVariant = root.getAttribute('data-variant-light');
      if (!darkVariant || !lightVariant) return;
      var LIGHT_THEMES = ['arctic'];

      function pick(theme) {
        return LIGHT_THEMES.indexOf(theme || '') !== -1 ? lightVariant : darkVariant;
      }
      function apply(theme) {
        var variant = pick(theme);
        var next = '/generated/profile-3d-contrib/' + variant + '.svg';
        document.querySelectorAll('img[data-contrib-3d-img="true"]').forEach(function (img) {
          if (img.src.indexOf(next) === -1) img.src = next;
        });
      }

      apply(document.documentElement.getAttribute('data-theme'));

      var obs = new MutationObserver(function (mutations) {
        for (var i = 0; i < mutations.length; i++) {
          if (mutations[i].attributeName === 'data-theme') {
            apply(document.documentElement.getAttribute('data-theme'));
            return;
          }
        }
      });
      obs.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    })();
    `}
  </script>
)}

<style lang="scss">
  @use '../styles/mixins' as *;

  .contrib-3d {
    margin: var(--space-xl) 0 0;
    padding: var(--space-lg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    @include backdrop-blur;
    overflow-x: auto;
    text-align: center;
  }

  .contrib-3d-link {
    display: block;
    transition: transform var(--duration-normal) var(--ease-out-expo);

    &:hover,
    &:focus-visible {
      transform: translateY(-2px);
    }
  }

  .contrib-3d img {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
    transition: filter var(--duration-normal) var(--ease-out-expo), opacity var(--duration-normal) var(--ease-out-expo);
  }

  .contrib-3d--themed img {
    filter:
      hue-rotate(var(--contrib-3d-hue, 0deg))
      saturate(var(--contrib-3d-sat, 1))
      brightness(var(--contrib-3d-bright, 1));
  }

  figcaption {
    margin-top: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  @include respond-to(mobile) {
    .contrib-3d {
      padding: var(--space-md);
    }
  }
</style>
